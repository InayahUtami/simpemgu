// --- Pie Chart for Kepadatan Penduduk ---

function PieKepadatanPenduduk({ mode, year, jumlahPendudukData, luasWilayahData }: { 
  mode: 'kecamatan' | 'tahun'; 
  year: number;
  jumlahPendudukData: any[];
  luasWilayahData: any[];
}) {
  const [data, setData] = React.useState<{ name: string; value: number }[]>([]);
  React.useEffect(() => {
    if (!jumlahPendudukData.length || !luasWilayahData.length) {
      setData([]);
      return;
    }
    try {
      if (mode === 'kecamatan') {
        // Hitung kepadatan untuk setiap kecamatan di tahun yang dipilih
        const pieData = jumlahPendudukData.map((jpItem: any) => {
          const kecamatanName = jpItem.kecamatan;
          const jumlahPenduduk = jpItem.dataByYear?.[year]?.jumlahPenduduk || 0;
          const luasItem = luasWilayahData.find((lw: any) => lw.kecamatan === kecamatanName);
          const luasWilayah = luasItem?.dataByYear?.[year]?.luasWilayah || 0;
          const value = luasWilayah > 0 ? jumlahPenduduk / luasWilayah : 0;
          return { name: kecamatanName, value };
        }).filter((d: { name: string; value: number }) => d.value > 0);
        setData(pieData);
      } else if (mode === 'tahun') {
        // Pie: total kepadatan per tahun (semua kecamatan dijumlahkan per tahun)
        // Ambil semua tahun yang ada
        const yearSet = new Set<number>();
        jumlahPendudukData.forEach((item: any) => {
          Object.keys(item.dataByYear || {}).forEach((year: string) => yearSet.add(parseInt(year)));
        });
        const years = Array.from(yearSet).sort((a, b) => a - b);
        const pieData = years.map(year => {
          // Total jumlah penduduk dan total luas wilayah untuk tahun ini
          let totalPenduduk = 0;
          let totalLuas = 0;
          jumlahPendudukData.forEach((jpItem: any) => {
            totalPenduduk += jpItem.dataByYear?.[year]?.jumlahPenduduk || 0;
            const luasItem = luasWilayahData.find((lw: any) => lw.kecamatan === jpItem.kecamatan);
            totalLuas += luasItem?.dataByYear?.[year]?.luasWilayah || 0;
          });
          const value = totalLuas > 0 ? totalPenduduk / totalLuas : 0;
          return { name: String(year), value };
        }).filter((d: { name: string; value: number }) => d.value > 0);
        setData(pieData);
      }
    } catch (e) {
      setData([]);
    }
  }, [mode, year, jumlahPendudukData, luasWilayahData]);
  const COLORS = [
    '#2563eb', '#60a5fa', '#93c5fd', '#fbbf24', '#34d399', '#f472b6', '#facc15', '#38bdf8',
    '#eab308', '#22d3ee', '#e11d48', '#84cc16', '#f43f5e', '#0ea5e9', '#f59e42',
    '#a3a3a3', '#d97706', '#be185d', '#fcd34d', '#10b981', '#93c5fd', '#a3e635',
    '#f43f5e', '#eab308', '#22d3ee', '#e11d48', '#84cc16', '#f43f5e', '#0ea5e9', '#f59e42',
    '#fcd34d', '#10b981', '#93c5fd', '#a3e635', '#93c5fd', '#fbbf24', '#34d399', '#f472b6', '#facc15', '#38bdf8',
    '#a3a3a3', '#d97706', '#be185d'
  ]; // Tanpa warna ungu
  if (!data.length) {
    return <div style={{ background: 'white', borderRadius: '16px', padding: '24px', margin: '16px 0', boxShadow: '0 4px 16px rgba(37,99,235,0.08)', border: '1.5px solid #e5e7eb', maxWidth: 500, textAlign: 'center', color: '#64748b' }}>
      <b>Data kepadatan penduduk tidak ditemukan atau kosong.</b>
    </div>;
  }
  // Format angka ribuan (tanpa desimal)
  const formatRibuan = (n: number) => n.toLocaleString('id-ID', { maximumFractionDigits: 0 });
  const isMobileView = typeof window !== 'undefined' && window.innerWidth < 768;
  return (
    <div style={{ background: 'white', borderRadius: isMobileView ? '12px' : '24px', padding: isMobileView ? '16px' : '56px', margin: '16px 0', boxShadow: '0 12px 40px rgba(37,99,235,0.16)', border: '2.5px solid #e5e7eb', maxWidth: '100%', width: '100%', minHeight: isMobileView ? 'auto' : 700, height: 'auto', position: 'relative' }}>
      <h4 style={{ fontSize: isMobileView ? '16px' : '18px', fontWeight: 700, color: '#2563eb', marginBottom: 12, textAlign: 'center' }}>Kepadatan Penduduk per Kecamatan (BPS)</h4>
      <div style={{ width: '100%', height: isMobileView ? '400px' : '540px', position: 'relative', display: 'block' }}>
        <ResponsiveContainer width="100%" height={isMobileView ? 400 : 540}>
        <PieChart>
          <Pie
            data={data}
            dataKey="value"
            nameKey="name"
            cx="50%"
            cy="50%"
            outerRadius={isMobileView ? 100 : 180}
            label={({ value }: any) => formatRibuan(value)}
          >
            {data.map((entry, idx) => <Cell key={`cell-kepadatan-${entry.name}-${idx}`} fill={COLORS[idx % COLORS.length]} />)}
          </Pie>
          <Tooltip formatter={(value: any) => `${formatRibuan(value)} org/kmÂ²`} />
          <Legend 
            wrapperStyle={{ 
              fontSize: isMobileView ? '10px' : '12px', 
              fontWeight: 500, 
              letterSpacing: '0.1px', 
              margin: 0, 
              padding: isMobileView ? '0 4px' : 0,
              maxHeight: isMobileView ? '120px' : 'none',
              overflowY: isMobileView ? 'auto' : 'visible'
            }} 
            iconSize={isMobileView ? 8 : 10}
            layout={isMobileView ? 'vertical' : 'horizontal'}
            align={isMobileView ? 'center' : 'center'}
            verticalAlign={isMobileView ? 'bottom' : 'bottom'}
          />
        </PieChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}

// --- Pie Chart for Persentase Penduduk ---
function PiePersentasePenduduk({ mode, year, jumlahPendudukData }: { 
  mode: 'kecamatan' | 'tahun'; 
  year: number;
  jumlahPendudukData: any[];
}) {
  const [data, setData] = React.useState<{ name: string; value: number }[]>([]);
  React.useEffect(() => {
    if (!jumlahPendudukData.length) return setData([]);
    try {
      if (mode === 'kecamatan') {
        // Hitung total penduduk tahun ini
        let totalPenduduk = 0;
        jumlahPendudukData.forEach((item: any) => {
          totalPenduduk += item.dataByYear?.[year]?.jumlahPenduduk || 0;
        });
        
        // Hitung persentase untuk setiap kecamatan di tahun yang dipilih
        const pieData = jumlahPendudukData.map((item: any) => {
          const jumlah = item.dataByYear?.[year]?.jumlahPenduduk || 0;
          const persentase = totalPenduduk > 0 ? (jumlah / totalPenduduk) * 100 : 0;
          return {
            name: item.kecamatan,
            value: Number(persentase.toFixed(2))
          };
        }).filter((d: { name: string; value: number }) => d.value > 0);
        setData(pieData);
      } else if (mode === 'tahun') {
        // Pie: satu slice per tahun, value selalu 100%
        // Ambil semua tahun yang ada
        const yearSet = new Set<number>();
        jumlahPendudukData.forEach((item: any) => {
          Object.keys(item.dataByYear || {}).forEach((year: string) => yearSet.add(parseInt(year)));
        });
        const years = Array.from(yearSet).sort((a, b) => a - b);
        const pieData = years.map(year => ({ name: String(year), value: 100 }));
        setData(pieData);
      }
    } catch { setData([]); }
  }, [mode, year, jumlahPendudukData]);
  const COLORS = [
    '#2563eb', '#60a5fa', '#93c5fd', '#fbbf24', '#34d399', '#f472b6', '#facc15', '#38bdf8',
    '#eab308', '#22d3ee', '#e11d48', '#84cc16', '#f43f5e', '#0ea5e9', '#f59e42',
    '#a3a3a3', '#d97706', '#be185d', '#fcd34d', '#10b981', '#93c5fd', '#a3e635',
    '#f43f5e', '#eab308', '#22d3ee', '#e11d48', '#84cc16', '#f43f5e', '#0ea5e9', '#f59e42',
    '#fcd34d', '#10b981', '#93c5fd', '#a3e635', '#93c5fd', '#fbbf24', '#34d399', '#f472b6', '#facc15', '#38bdf8',
    '#a3a3a3', '#d97706', '#be185d'
  ]; // Tanpa warna ungu
  const isMobileView = typeof window !== 'undefined' && window.innerWidth < 768;
  return (
    <div style={{ background: 'white', borderRadius: isMobileView ? '12px' : '24px', padding: isMobileView ? '16px' : '56px', margin: '16px 0', boxShadow: '0 12px 40px rgba(139,92,246,0.16)', border: '2.5px solid #e5e7eb', maxWidth: '100%', width: '100%', minHeight: isMobileView ? 'auto' : 700, height: 'auto' }}>
      <h4 style={{ fontSize: isMobileView ? '16px' : '18px', fontWeight: 700, color: '#8B5CF6', marginBottom: 12, textAlign: 'center' }}>Persentase Penduduk per Kecamatan (BPS)</h4>
      <div style={{ width: '100%', height: isMobileView ? '400px' : '540px', position: 'relative', display: 'block' }}>
        <ResponsiveContainer width="100%" height={isMobileView ? 400 : 540}>
        <PieChart>
          <Pie data={data} dataKey="value" nameKey="name" cx="50%" cy="50%" outerRadius={isMobileView ? 100 : 180} label={true}>
            {data.map((entry, idx) => <Cell key={`cell-persentase-${entry.name}-${idx}`} fill={COLORS[idx % COLORS.length]} />)}
          </Pie>
          <Tooltip formatter={(value: any) => `${value}%`} />
          <Legend 
            wrapperStyle={{ 
              fontSize: isMobileView ? '10px' : '12px', 
              fontWeight: 500, 
              letterSpacing: '0.1px', 
              margin: 0, 
              padding: isMobileView ? '0 4px' : 0,
              maxHeight: isMobileView ? '120px' : 'none',
              overflowY: isMobileView ? 'auto' : 'visible'
            }} 
            iconSize={isMobileView ? 8 : 10}
            layout={isMobileView ? 'vertical' : 'horizontal'}
            align={isMobileView ? 'center' : 'center'}
            verticalAlign={isMobileView ? 'bottom' : 'bottom'}
          />
        </PieChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}

// ========== End of chart components ==========

  return (
    <div className="user-content-zoom" style={{ 
      minHeight: '100vh',
      background: '#ffffff',
      width: '100%',
      overflow: 'auto',
      display: 'flex',
      flexDirection: 'column',
