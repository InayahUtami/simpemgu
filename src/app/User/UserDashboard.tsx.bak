              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              transition: 'all 0.3s ease',
              zIndex: 1000
            }}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'scale(1.1)';
              e.currentTarget.style.boxShadow = '0 12px 32px rgba(102,126,234,0.5)';
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = '0 8px 24px rgba(102,126,234,0.4)';
            }}
          >
            <svg width="32" height="32" viewBox="0 0 24 24" fill="white">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 3 .97 4.29L2 22l5.71-.97C9 21.64 10.46 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
            </svg>
          </button>

          {/* Chatbot Modal Panel */}
          {isChatbotOpen && (
            <>
              <div
                style={{
                  position: 'fixed',
                  bottom: isMobile ? '88px' : '108px',
                  right: isMobile ? '10px' : '32px',
                  width: isMobile ? 'calc(100vw - 20px)' : '480px',
                  maxWidth: isMobile ? 'calc(100vw - 20px)' : '95vw',
                  maxHeight: isMobile ? '40vh' : '600px',
                  background: 'white',
                  borderRadius: isMobile ? '12px' : '16px',
                  boxShadow: '0 16px 48px rgba(0,0,0,0.2)',
                  zIndex: 999,
                  display: 'flex',
                  flexDirection: 'column',
                  overflow: 'hidden',
                  animation: 'slideUp 0.3s ease-out'
                }}
              >
              {/* Header */}
              <div style={{
                background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                padding: isMobile ? '12px 16px' : '20px 24px',
                color: 'white',
                borderTopLeftRadius: isMobile ? '12px' : '16px',
                borderTopRightRadius: isMobile ? '12px' : '16px'
              }}>
                <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                  <div style={{ display: 'flex', alignItems: 'center', gap: isMobile ? '8px' : '12px', flex: 1 }}>
                    <div>
                      <h3 style={{ margin: 0, fontSize: isMobile ? '14px' : '18px', fontWeight: '700' }}>
                        ðŸ¤– {isAnalysisShown ? 'Asisten Data' : 'Hallo, Saya Asisten Data'}
                      </h3>
                      {!isAnalysisShown && (
                        <p style={{ margin: 0, fontSize: isMobile ? '11px' : '13px', opacity: 0.9, marginTop: '4px' }}>
                          {activeTab === 'overview' && 'Silahkan klik tombol mulai dibawah ini untuk membaca Interpretasi Grafik Tinjauan Umum'}
                          {activeTab === 'districts' && 'Silahkan klik tombol mulai dibawah ini untuk membaca Interpretasi Grafik Populasi'}
                          {activeTab === 'demographics' && 'Silahkan klik tombol mulai dibawah ini untuk membaca Interpretasi Grafik Demografi'}
                          {activeTab === 'growth' && 'Silahkan klik tombol mulai dibawah ini untuk membaca Interpretasi Luas Wilayah'}
                        </p>
                      )}
                    </div>
                  </div>
                  
                  {/* Header Buttons */}
                  <div style={{ display: 'flex', gap: '8px', alignItems: 'center' }}>
                    {isAnalysisShown && (
                      <button
                        onClick={() => {
                          setIsAnalysisShown(false);
                          setRefreshTrigger(prev => prev + 1);
                        }}
                        style={{
                          background: 'rgba(255, 255, 255, 0.2)',
                          border: 'none',
                          color: 'white',
                          width: isMobile ? '40px' : '36px',
                          height: isMobile ? '40px' : '36px',
                          minWidth: isMobile ? '40px' : '36px',
                          minHeight: isMobile ? '40px' : '36px',
                          borderRadius: '8px',
                          cursor: 'pointer',
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'center',
                          transition: 'all 0.2s',
                          WebkitTapHighlightColor: 'transparent',
                          touchAction: 'manipulation',
                          flexShrink: 0
                        }}
                        onMouseEnter={(e) => {
                          if (!isMobile) e.currentTarget.style.background = 'rgba(255, 255, 255, 0.3)';
                        }}
                        onMouseLeave={(e) => {
                          if (!isMobile) e.currentTarget.style.background = 'rgba(255, 255, 255, 0.2)';
                        }}
                        onTouchStart={(e) => {
                          e.currentTarget.style.background = 'rgba(255, 255, 255, 0.3)';
                        }}
                        onTouchEnd={(e) => {
                          e.currentTarget.style.background = 'rgba(255, 255, 255, 0.2)';
                        }}
                        title="Refresh"
                      >
                        <svg width={isMobile ? '20' : '20'} height={isMobile ? '20' : '20'} viewBox="0 0 24 24" fill="none" stroke="white" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" style={{ pointerEvents: 'none' }}>
                          <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>
                        </svg>
                      </button>
                    )}
                    
                    {/* Close Button */}
                    <button
                      onClick={() => setIsChatbotOpen(false)}
                      style={{
                        background: 'rgba(255, 255, 255, 0.2)',
                        border: 'none',
                        color: 'white',
                        width: isMobile ? '32px' : '32px',
                        height: isMobile ? '32px' : '32px',
                        minWidth: isMobile ? '32px' : '32px',
                        minHeight: isMobile ? '32px' : '32px',
                        borderRadius: '8px',
                        cursor: 'pointer',
                        display: 'flex',
                        alignItems: 'center',
                        justifyContent: 'center',
                        transition: 'all 0.2s',
                        WebkitTapHighlightColor: 'transparent',
                        touchAction: 'manipulation',
                        flexShrink: 0
                      }}
                      onMouseEnter={(e) => {
                        if (!isMobile) e.currentTarget.style.background = 'rgba(255, 255, 255, 0.3)';
                      }}
                      onMouseLeave={(e) => {
                        if (!isMobile) e.currentTarget.style.background = 'rgba(255, 255, 255, 0.2)';
                      }}
                      onTouchStart={(e) => {
                        e.currentTarget.style.background = 'rgba(255, 255, 255, 0.3)';
                      }}
                      onTouchEnd={(e) => {
                        e.currentTarget.style.background = 'rgba(255, 255, 255, 0.2)';
                      }}
                      title="Tutup"
                    >
                      <svg width={isMobile ? '16' : '16'} height={isMobile ? '16' : '16'} viewBox="0 0 24 24" fill="none" stroke="white" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" style={{ pointerEvents: 'none' }}>
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>

              {/* Content */}
              <div style={{
                flex: 1,
                overflowY: 'auto',
                padding: isMobile ? '12px' : '20px',
                background: '#f9fafb'
              }}>
                <ComprehensiveDashboardAnalysis
                  activeTab={activeTab}
                  pertumbuhanData={pertumbuhanData || []}
                  jumlahPendudukData={(() => {
                    const yearMap = new Map<number, number>();
                    try {
                      if (selectedDistrict) {
                        const kecamatan = jumlahPendudukDataFromDB.find((item: any) => item.kecamatan === selectedDistrict);
                        if (kecamatan && kecamatan.dataByYear) {
                          Object.entries(kecamatan.dataByYear).forEach(([yearStr, val]: [string, any]) => {
                            const year = parseInt(yearStr);
                            yearMap.set(year, val?.jumlahPenduduk ?? 0);
                          });
                        }
                      } else {
                        jumlahPendudukDataFromDB.forEach((item: any) => {
                          Object.entries(item.dataByYear || {}).forEach(([yearStr, val]: [string, any]) => {
                            const year = parseInt(yearStr);
                            const current = yearMap.get(year) || 0;
                            yearMap.set(year, current + (val?.jumlahPenduduk ?? 0));
                          });
                        });
                      }
                    } catch (e) {
                      console.error('Error processing jumlahPendudukData', e);
                    }
                    return Array.from(yearMap.entries())
                      .map(([year, jumlahPenduduk]) => ({ year, jumlahPenduduk }))
                      .sort((a, b) => a.year - b.year);
                  })()}
                  jumlahPendudukDisdukcapilData={(() => {
                    const yearMap = new Map<number, number>();
                    try {
                      if (selectedDistrict) {
                        const kecamatan = jumlahPendudukDisdukcapilDataFromDB.find((item: any) => item.kecamatan === selectedDistrict);
                        if (kecamatan && kecamatan.dataByYear) {
                          Object.entries(kecamatan.dataByYear).forEach(([yearStr, val]: [string, any]) => {
                            const year = parseInt(yearStr);
                            yearMap.set(year, val?.jumlahPendudukDisdukcapil ?? 0);
                          });
                        }
                      } else {
                        jumlahPendudukDisdukcapilDataFromDB.forEach((item: any) => {
                          Object.entries(item.dataByYear || {}).forEach(([yearStr, val]: [string, any]) => {
                            const year = parseInt(yearStr);
                            const current = yearMap.get(year) || 0;
                            yearMap.set(year, current + (val?.jumlahPendudukDisdukcapil ?? 0));
                          });
                        });
                      }
                    } catch (e) {
                      console.error('Error processing jumlahPendudukDisdukcapilData', e);
                    }
                    return Array.from(yearMap.entries())
                      .map(([year, jumlahPendudukDisdukcapil]) => ({ year, jumlahPendudukDisdukcapil }))
                      .sort((a, b) => a.year - b.year);
                  })()}
                  kelahiranData={kelahiranDataFromDB}
                  kematianData={kematianDataFromDB}
                  migrasiData={migrasiDataFromDB}
                  pyramidData={(() => {
                    try {
                      return getPyramidData() || [];
                    } catch (e) {
                      console.error('Error getPyramidData', e);
                      return [];
                    }
                  })()}
                  kepadatanData={(() => {
                    try {
                      if (jumlahPendudukDataFromDB.length === 0 || luasWilayahDataFromDB.length === 0) return [];
                      const selectedYearForDensity = selectedYear || new Date().getFullYear();
                      const filteredData = selectedDistrict 
                        ? jumlahPendudukDataFromDB.filter((item: any) => item.kecamatan === selectedDistrict)
                        : jumlahPendudukDataFromDB;
                      return filteredData.map((jpItem: any) => {
                        const luasItem = luasWilayahDataFromDB.find((lw: any) => lw.kecamatan === jpItem.kecamatan);
                        const luas = luasItem?.luas || 1;
                        const penduduk = jpItem.dataByYear?.[selectedYearForDensity]?.jumlahPenduduk || 0;
                        return { name: jpItem.kecamatan, value: luas > 0 ? penduduk / luas : 0 };
                      }).filter((d: any) => d.value > 0);
                    } catch (e) {
                      console.error('Error processing kepadatanData', e);
                      return [];
                    }
                  })()}
                  selectedDistrict={selectedDistrict || ''}
                  yearRange={yearRange || { from: 2018, to: 2024 }}
                  selectedYear={selectedYear}
                  pieKepadatanMode={pieKepadatanMode}
                  kepYear={kepYear}
                  piePersentaseMode={piePersentaseMode}
                  persYear={persYear}
                  jumlahPendudukDataFromDB={jumlahPendudukDataFromDB}
                  luasWilayahDataFromDB={luasWilayahDataFromDB}
                  demogYear={demogYear}
                  pieLuasMode={pieLuasMode}
                  pieLuasYear={pieLuasYear}
                  pieLuasAvailableYears={pieLuasAvailableYears}
                  kelompokUmurDataFromDB={kelompokUmurDataFromDB}
                  onShowAnalysisChange={(show) => setIsAnalysisShown(show)}
                  onRefresh={() => setIsAnalysisShown(false)}
                  refreshTrigger={refreshTrigger}
                />
              </div>
            </div>
            </>
          )}
          
          <style jsx global>{`
            @keyframes slideUp {
              from {
                opacity: 0;
                transform: translateY(20px);
              }
              to {
                opacity: 1;
                transform: translateY(0);
              }
            }
          `}</style>
          
          {/* Footer with Logos */}
          <Footer />
    </div>
  );
}


