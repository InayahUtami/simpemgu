                        <div style={{
                          position: 'absolute',
                          top: '40px',
                          left: 0,
                          right: 0,
                          zIndex: 100,
                          background: 'white',
                          border: '1px solid #e5e7eb',
                          borderRadius: '8px',
                          boxShadow: '0 2px 8px rgba(0,0,0,0.06)',
