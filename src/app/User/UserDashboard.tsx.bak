    })).filter(d => d.value > 0);
  }, [luasWilayahData, pieLuasAvailableYears]);
  const pieLuasColors = ['#93c5fd', '#60a5fa', '#34d399', '#fbbf24', '#a78bfa', '#f472b6', '#facc15', '#38bdf8', '#eab308', '#22d3ee', '#e11d48', '#84cc16', '#f43f5e', '#0ea5e9', '#f59e42'];
  
