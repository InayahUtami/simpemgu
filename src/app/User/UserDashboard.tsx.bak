                          <>
                            <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                              <input type="number" min={availableYears[0] ?? 2018} max={yearRange.to} value={yearRange.from} onChange={e => setYearRange(r => ({ ...r, from: Math.max(availableYears[0] ?? 2018, Math.min(Number(e.target.value), r.to)) }))} style={{ width: isMobile ? '60px' : '100px', padding: isMobile ? '6px 4px' : '8px 12px', borderRadius: '8px', border: '1.5px solid #38bdf8', fontWeight: 500, fontSize: isMobile ? '12px' : '13px', background: 'white', WebkitAppearance: isMobile ? 'none' : undefined, MozAppearance: isMobile ? 'textfield' : undefined }} />
                              <div style={{ display: isMobile ? 'flex' : 'none', flexDirection: 'column', gap: '2px' }}>
                                <button onClick={() => setYearRange(r => ({ ...r, from: Math.min(r.from + 1, r.to) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–²</button>
                                <button onClick={() => setYearRange(r => ({ ...r, from: Math.max(availableYears[0] ?? 2018, r.from - 1) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–¼</button>
                              </div>
                            </div>
                            <span style={{ fontWeight: 700, fontSize: isMobile ? '12px' : '14px' }}>â€”</span>
                            <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                              <input type="number" min={yearRange.from} max={availableYears[availableYears.length-1] ?? 2027} value={yearRange.to} onChange={e => setYearRange(r => ({ ...r, to: Math.min(availableYears[availableYears.length-1] ?? 2027, Math.max(Number(e.target.value), r.from)) }))} style={{ width: isMobile ? '60px' : '100px', padding: isMobile ? '6px 4px' : '8px 12px', borderRadius: '8px', border: '1.5px solid #38bdf8', fontWeight: 500, fontSize: isMobile ? '12px' : '13px', background: 'white', WebkitAppearance: isMobile ? 'none' : undefined, MozAppearance: isMobile ? 'textfield' : undefined }} />
                              <div style={{ display: isMobile ? 'flex' : 'none', flexDirection: 'column', gap: '2px' }}>
                                <button onClick={() => setYearRange(r => ({ ...r, to: Math.min(availableYears[availableYears.length-1] ?? 2027, r.to + 1) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–²</button>
                                <button onClick={() => setYearRange(r => ({ ...r, to: Math.max(r.from, r.to - 1) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–¼</button>
                              </div>
                            </div>
                          </>
                        ) : (
                          <>
                            <input type="number" readOnly value={availableYears[0] ?? 2018} style={{ width: '100px' }} />
                            <span style={{ fontWeight: 700 }}>â€”</span>
                            <input type="number" readOnly value={availableYears[availableYears.length-1] ?? 2027} style={{ width: '100px' }} />
                          </>
                        )}
                      </div>
                    </div>
                  </div>

                  <div style={{ display: 'flex', flexDirection: isMobile ? 'column' : 'row', gap: isMobile ? '24px' : '32px', alignItems: 'stretch' }}>
                    <div 
                      className="scroll-reveal-left delay-700 hover-lift"
                      style={{ 
                        flex: 1, 
                        minWidth: 0, 
                        backgroundColor: 'white', 
                        borderRadius: '12px', 
                        padding: isMobile ? '16px' : '18px', 
                        boxShadow: '0 4px 6px -1px rgba(0,0,0,0.1)',
                        transition: 'all 0.3s ease',
                        minHeight: isMobile ? '350px' : '380px',
                        position: 'relative'
                      }}>
                      <div style={{ width: '100%', height: '300px', position: 'relative', display: 'block' }}>
                        <ResponsiveContainer width="100%" height={300}>
                        <AreaChart data={pertumbuhanData.filter(d => d.year >= yearRange.from && d.year <= yearRange.to)}>
                          <defs>
                            <linearGradient id="colorTingkat" x1="0" y1="0" x2="0" y2="1">
                              <stop offset="5%" stopColor="#8B5CF6" stopOpacity={0.3}/>
                              <stop offset="95%" stopColor="#8B5CF6" stopOpacity={0.05}/>
                            </linearGradient>
                          </defs>
                          <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                          <XAxis dataKey="year" stroke="#6b7280" style={{ fontSize: '12px', fontWeight: 400 }} />
                          <YAxis stroke="#6b7280" tickFormatter={tick => `${Number(tick).toFixed(2)}%`} style={{ fontSize: '12px', fontWeight: 400 }} />
                          <Tooltip formatter={(value) => `${Number(value).toFixed(2)}%`} contentStyle={{ backgroundColor: 'white', border: '1px solid #e5e7eb', borderRadius: '8px', fontWeight: 400 }} />
                          <Area type="monotone" dataKey="tingkat" stroke="#8B5CF6" strokeWidth={3} fill="url(#colorTingkat)" name="Laju Pertumbuhan (BPS)" dot={{ r: 3 }} />
                        </AreaChart>
                        </ResponsiveContainer>
                      </div>
                      {/* Custom legend for purple chart, placed below the chart */}
                      <div style={{ marginTop: '8px', display: 'flex', justifyContent: 'center' }}>
                        <div style={{ background: 'white', borderRadius: '8px', padding: '6px 10px', boxShadow: '0 2px 6px rgba(0,0,0,0.06)', border: '1px solid #e5e7eb' }}>
                          <span style={{ display: 'inline-flex', alignItems: 'center', gap: '8px', fontSize: '13px', color: '#374151', fontWeight: 600 }}>
                            <svg width="12" height="12" viewBox="0 0 32 32" style={{ display: 'inline-block', verticalAlign: 'middle' }} aria-hidden>
                              <circle cx="16" cy="16" r="8" fill="#8B5CF6" />
                            </svg>
                            <span style={{ color: '#8B5CF6' }}>Laju Pertumbuhan Penduduk (BPS)</span>
                          </span>
                        </div>
                      </div>
                    </div>
                    <div className="scroll-reveal-right delay-800" style={{ flex: 1, minWidth: 0 }}>
                      <GrafikLPLKMPerKecamatan 
                        selectedDistrict={selectedDistrict} 
                        yearRange={yearRange}
                        kelahiranData={kelahiranDataFromDB}
                        kematianData={kematianDataFromDB}
                        migrasiData={migrasiDataFromDB}
                        pendudukData={jumlahPendudukDisdukcapilDataFromDB}
                      />
                    </div>
                  </div>
                    {/* Grafik Jumlah Penduduk BPS dan Disdukcapil dipindahkan ke sini dari districts */}
                    <div style={{ display: 'flex', flexDirection: isMobile ? 'column' : 'row', gap: isMobile ? '24px' : '32px', alignItems: 'stretch', marginTop: '32px', maxWidth: '100%', width: '100%' }}>
                      {/* Grafik Jumlah Penduduk BPS */}
                      <div 
                        className="scroll-reveal delay-900 hover-lift"
                        style={{ 
                          flex: 1, 
                          backgroundColor: 'white', 
                          borderRadius: isMobile ? 0 : '16px', 
                          padding: '32px', 
                          boxShadow: '0 8px 24px rgba(37,99,235,0.10)', 
                          border: '1.5px solid #e5e7eb',
                          transition: 'all 0.3s ease',
                          minHeight: isMobile ? '480px' : '520px',
                          position: 'relative'
                        }}>
                        <div style={{ width: '100%', height: '420px', position: 'relative', display: 'block' }}>
                          <ResponsiveContainer width="100%" height={420}>
                          {selectedDistrict ? (
                            <BarChart
                              data={(() => {
                                const kecamatan = jumlahPendudukDataFromDB.find((item: any) => item.kecamatan === selectedDistrict);
                                if (!kecamatan || !kecamatan.dataByYear) return [];
                                const data: { year: number; jumlahPenduduk: number }[] = [];
                                for (let y = yearRange.from; y <= yearRange.to; y++) {
                                  data.push({
                                    year: y,
                                    jumlahPenduduk: kecamatan.dataByYear[y]?.jumlahPenduduk ?? 0
                                  });
                                }
                                return data;
                              })()}
                              margin={{ top: 20, right: 40, left: 0, bottom: 20 }}
                            >
                              <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                              <XAxis dataKey="year" stroke="#6b7280" fontSize={16} />
                              <YAxis stroke="#6b7280" />
                              <Tooltip formatter={v => (v ?? 0).toLocaleString('id-ID')} contentStyle={{ backgroundColor: 'white', border: '1.5px solid #e5e7eb', borderRadius: '12px' }} />
                              <Bar dataKey="jumlahPenduduk" fill="#8B5CF6" name="Jumlah Penduduk" radius={[8, 8, 0, 0]} />
                            </BarChart>
                          ) : (
                            <BarChart
                              data={(() => {
                                // Aggregate total population per year
                                const yearSet = new Set<number>();
                                jumlahPendudukDataFromDB.forEach((item: any) => {
                                  Object.keys(item.dataByYear || {}).forEach((y: string) => yearSet.add(parseInt(y)));
                                });
                                const years = Array.from(yearSet).sort((a, b) => a - b).filter(y => y >= yearRange.from && y <= yearRange.to);
                                return years.map(year => {
                                  const total = jumlahPendudukDataFromDB.reduce((sum: number, item: any) => sum + (item.dataByYear?.[year]?.jumlahPenduduk ?? 0), 0);
                                  return { year, jumlahPenduduk: total };
                                });
                              })()}
                              margin={{ top: 20, right: 40, left: 0, bottom: 20 }}
                            >
                              <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                              <XAxis dataKey="year" stroke="#6b7280" fontSize={16} />
                              <YAxis stroke="#6b7280" />
                              <Tooltip formatter={v => (v ?? 0).toLocaleString('id-ID')} contentStyle={{ backgroundColor: 'white', border: '1.5px solid #e5e7eb', borderRadius: '12px' }} />
                              <Bar dataKey="jumlahPenduduk" fill="#8B5CF6" name="Jumlah Penduduk" radius={[8, 8, 0, 0]} />
                            </BarChart>
                          )}
                          </ResponsiveContainer>
                        </div>
                        {/* Custom legend visually under X-axis, inside chart area */}
                        <div style={{
                          marginTop: '-12px',
                          display: 'flex',
                          justifyContent: 'center',
                          pointerEvents: 'none',
                          position: 'relative',
                          zIndex: 2
                        }}>
                          <div style={{
                            background: 'white',
                            borderRadius: '8px',
                            padding: '4px 12px',
                            boxShadow: '0 2px 6px rgba(0,0,0,0.06)',
                            border: '1px solid #e5e7eb',
                            fontSize: '13px',
                            color: '#374151',
                            fontWeight: 600,
                            display: 'inline-flex',
                            alignItems: 'center',
                            gap: '8px'
                          }}>
                            <svg width="12" height="12" viewBox="0 0 32 32" style={{ display: 'inline-block', verticalAlign: 'middle' }} aria-hidden>
                              <rect x="6" y="6" width="20" height="20" rx="4" fill="#8B5CF6" />
                            </svg>
                            <span style={{ color: '#8B5CF6' }}>Jumlah Penduduk (BPS)</span>
                          </div>
                        </div>
                      </div>
                      {/* Grafik Jumlah Penduduk Dinas Pendidikan Kota Palembang */}
                      <div 
                        className="scroll-reveal delay-1000 hover-lift"
                        style={{ 
                          flex: 1, 
                          backgroundColor: 'white', 
                          borderRadius: isMobile ? 0 : '16px', 
                          padding: '32px', 
                          boxShadow: '0 8px 24px rgba(124,58,237,0.10)', 
                          border: '1.5px solid #e5e7eb',
                          transition: 'all 0.3s ease',
                          minHeight: isMobile ? '480px' : '520px'
                        }}>
                        <div style={{ width: '100%', height: '420px', position: 'relative', display: 'block' }}>
                          <ResponsiveContainer width="100%" height={420}>
                          {selectedDistrict ? (
                            <BarChart
                              data={(() => {
                                const kecamatan = jumlahPendudukDisdukcapilDataFromDB.find((item: any) => item.kecamatan === selectedDistrict);
                                if (!kecamatan || !kecamatan.dataByYear) return [];
                                const data: { year: number; jumlahPendudukDisdukcapil: number }[] = [];
                                for (let y = yearRange.from; y <= yearRange.to; y++) {
                                  data.push({
                                    year: y,
                                    jumlahPendudukDisdukcapil: kecamatan.dataByYear[y]?.jumlahPendudukDisdukcapil ?? 0
                                  });
                                }
                                return data;
                              })()}
                              margin={{ top: 20, right: 40, left: 0, bottom: 20 }}
                            >
                              <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                              <XAxis dataKey="year" stroke="#a3a3a3" fontSize={16} />
                              <YAxis stroke="#a3a3a3" fontSize={16} />
                              <Tooltip formatter={v => (v ?? 0).toLocaleString('id-ID')} contentStyle={{ backgroundColor: 'white', border: '1.5px solid #e5e7eb', borderRadius: '12px' }} />
                              <Bar dataKey="jumlahPendudukDisdukcapil" fill="#2563eb" name="Jumlah Penduduk Dinas Pendidikan Kota Palembang" radius={[8, 8, 0, 0]} />
                            </BarChart>
                          ) : (
                            <BarChart
                              data={(() => {
                                // Aggregate total Disdukcapil population per year
                                const yearSet = new Set<number>();
                                jumlahPendudukDisdukcapilDataFromDB.forEach((item: any) => {
                                  Object.keys(item.dataByYear || {}).forEach((y: string) => yearSet.add(parseInt(y)));
                                });
                                const years = Array.from(yearSet).sort((a, b) => a - b).filter(y => y >= yearRange.from && y <= yearRange.to);
                                return years.map(year => {
                                  const total = jumlahPendudukDisdukcapilDataFromDB.reduce((sum: number, item: any) => sum + (item.dataByYear?.[year]?.jumlahPendudukDisdukcapil ?? 0), 0);
                                  return { year, jumlahPendudukDisdukcapil: total };
                                });
                              })()}
                              margin={{ top: 20, right: 40, left: 0, bottom: 20 }}
                            >
                              <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                              <XAxis dataKey="year" stroke="#a3a3a3" fontSize={16} />
                              <YAxis stroke="#a3a3a3" fontSize={16} />
                              <Tooltip formatter={v => (v ?? 0).toLocaleString('id-ID')} contentStyle={{ backgroundColor: 'white', border: '1.5px solid #e5e7eb', borderRadius: '12px' }} />
                              <Bar dataKey="jumlahPendudukDisdukcapil" fill="#2563eb" name="Jumlah Penduduk Dinas Pendidikan Kota Palembang" radius={[8, 8, 0, 0]} />
                            </BarChart>
                          )}
                          </ResponsiveContainer>
                        </div>
                        {/* Custom legend visually under X-axis, inside chart area */}
                        <div style={{
                          marginTop: '-12px',
                          display: 'flex',
                          justifyContent: 'center',
                          pointerEvents: 'none',
                          position: 'relative',
                          zIndex: 2
                        }}>
                          <div style={{
                            background: 'white',
                            borderRadius: '8px',
                            padding: '4px 12px',
                            boxShadow: '0 2px 6px rgba(0,0,0,0.06)',
                            border: '1px solid #e5e7eb',
                            fontSize: '13px',
                            color: '#374151',
                            fontWeight: 600,
                            display: 'inline-flex',
                            alignItems: 'center',
                            gap: '8px'
                          }}>
                            <svg width="12" height="12" viewBox="0 0 32 32" style={{ display: 'inline-block', verticalAlign: 'middle' }} aria-hidden>
                              <rect x="6" y="6" width="20" height="20" rx="4" fill="#2563eb" />
                            </svg>
                            <span style={{ color: '#2563eb' }}>Jumlah Penduduk Dinas Pendidikan Kota Palembang</span>
                          </div>
                        </div>
                      </div>
                    </div>
                </div>
              </div>
            )}
            {activeTab === 'districts' && (
              <div style={{ 
                maxWidth: isMobile ? '100%' : '1400px', 
                margin: '0 auto', 
                paddingLeft: isMobile ? '0' : '16px',
                paddingRight: isMobile ? '0' : '16px'
              }}>
                <div style={{
                  background: 'linear-gradient(90deg, rgba(37,99,235,0.18) 0%, rgba(96,165,250,0.18) 100%)',
                  borderRadius: isMobile ? '0' : '24px',
                  padding: isMobile ? '16px 12px' : '24px 32px',
                  marginBottom: '0px',
                  minHeight: isMobile ? 'auto' : '420px',
                  width: '100%'
                }}>
                  <h3 style={{ fontSize: isMobile ? '18px' : '22px', fontWeight: '700', color: '#1f2937', marginBottom: '16px' }}>
                    Statistik Jumlah Penduduk ({isClient ? yearRange.from : 2018} - {isClient ? yearRange.to : 2024})
                  </h3>
                  <div style={{ display: 'flex', flexDirection: isMobile ? 'column' : 'row', gap: isMobile ? '16px' : '32px', marginBottom: '18px' }}>
                    <div style={{ flex: 1 }}>
                      <div style={{ marginBottom: '8px', color: '#374151', fontWeight: 600 }}>Pilih Kecamatan</div>
                      <div style={{ position: 'relative', width: '100%' }}>
                        <div style={{ position: 'relative' }}>
                          <input
                            type="text"
                            value={selectedDistrictPopulasi}
                            onChange={e => setSelectedDistrictPopulasi(e.target.value)}
                            placeholder="Cari atau pilih kecamatan..."
                            style={{
                              fontSize: '13px',
                              padding: '8px 36px 8px 16px', // extra right padding for arrow
                              borderRadius: '8px',
                              border: '2px solid #38bdf8',
                              background: 'white',
                              fontWeight: 500,
                              width: '100%',
                              marginBottom: '6px'
                            }}
                          />
                          <span style={{
                            position: 'absolute',
                            right: '12px',
                            top: '50%',
                            transform: 'translateY(-50%)',
                            color: '#38bdf8',
                            fontSize: '18px',
                            display: 'flex',
                            alignItems: 'center'
                          }}>
                            <span
                              style={{ cursor: 'pointer', display: 'flex', alignItems: 'center' }}
                              onMouseDown={e => {
                                e.preventDefault();
                                setDropdownOpen(prev => !prev);
                                if (!dropdownOpen) {
                                  setSelectedDistrictPopulasi(''); // Reset search to show all kecamatan
                                }
                              }}
                            >
                              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M6 8L10 12L14 8" stroke="#38bdf8" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                              </svg>
                            </span>
                          </span>
                        </div>
                        <div style={{
                          position: 'absolute',
                          top: '40px',
                          left: 0,
                          right: 0,
                          zIndex: 10,
                          background: 'white',
                          border: '1px solid #e5e7eb',
                          borderRadius: '8px',
                          boxShadow: '0 2px 8px rgba(0,0,0,0.06)',
                          maxHeight: '180px',
                          overflowY: 'auto',
                          display: dropdownOpen ? 'block' : 'none'
                        }}>
                          <div
                            style={{
                              padding: '8px 16px',
                              cursor: 'pointer',
                              color: '#2563eb',
                              fontWeight: 600,
                              borderBottom: '1px solid #e5e7eb'
                            }}
                            onClick={() => {
                              setSelectedDistrict('');
                              setSelectedDistrictPopulasi('');
                              setDropdownOpen(false);
                            }}
                          >
                            Semua Kecamatan
                          </div>
                          {districtData
                            .filter(d => d.name.toLowerCase().includes(selectedDistrictPopulasi.toLowerCase()))
                            .map(d => (
                              <div
                                key={d.name}
                                style={{
                                  padding: '8px 16px',
                                  cursor: 'pointer',
                                  color: '#374151',
                                  fontWeight: 500,
                                  borderBottom: '1px solid #e5e7eb',
                                  background: selectedDistrictPopulasi === d.name ? '#f3f4f6' : 'white'
                                }}
                                onClick={() => {
                                  setSelectedDistrictPopulasi(d.name);
                                  setSelectedDistrict(d.name); // Sync with chart
                                  setDropdownOpen(false);
                                }}
                              >
                                {d.name}
                              </div>
                            ))}
                        </div>
                      </div>
                    </div>
                    <div style={{ flex: 1 }}>
                      <div style={{ marginBottom: '8px', color: '#374151', fontWeight: 600 }}>Filter Rentang Tahun</div>
                      <div style={{ display: 'flex', alignItems: 'center', gap: isMobile ? '6px' : '12px' }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <input type="number" style={{ width: isMobile ? '60px' : '100px', padding: isMobile ? '6px 4px' : '8px 12px', borderRadius: '8px', border: '1.5px solid #38bdf8', fontWeight: 500, fontSize: isMobile ? '12px' : '13px', background: 'white', WebkitAppearance: isMobile ? 'none' : undefined, MozAppearance: isMobile ? 'textfield' : undefined }} value={yearRange.from} min={availableYears[0] ?? 2018} max={yearRange.to} onChange={e => setYearRange(r => ({ ...r, from: Math.max(availableYears[0] ?? 2018, Math.min(Number(e.target.value), r.to)) }))} />
                          <div style={{ display: isMobile ? 'flex' : 'none', flexDirection: 'column', gap: '2px' }}>
                            <button onClick={() => setYearRange(r => ({ ...r, from: Math.min(r.from + 1, r.to) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–²</button>
                            <button onClick={() => setYearRange(r => ({ ...r, from: Math.max(availableYears[0] ?? 2018, r.from - 1) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–¼</button>
                          </div>
                        </div>
                        <span style={{ fontWeight: 700, fontSize: isMobile ? '12px' : '14px' }}>â€”</span>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '4px' }}>
                          <input type="number" style={{ width: isMobile ? '60px' : '100px', padding: isMobile ? '6px 4px' : '8px 12px', borderRadius: '8px', border: '1.5px solid #38bdf8', fontWeight: 500, fontSize: isMobile ? '12px' : '13px', background: 'white', WebkitAppearance: isMobile ? 'none' : undefined, MozAppearance: isMobile ? 'textfield' : undefined }} value={yearRange.to} min={yearRange.from} max={availableYears[availableYears.length-1] ?? 2024} onChange={e => setYearRange(r => ({ ...r, to: Math.min(availableYears[availableYears.length-1] ?? 2024, Math.max(Number(e.target.value), r.from)) }))} />
                          <div style={{ display: isMobile ? 'flex' : 'none', flexDirection: 'column', gap: '2px' }}>
                            <button onClick={() => setYearRange(r => ({ ...r, to: Math.min(availableYears[availableYears.length-1] ?? 2024, r.to + 1) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–²</button>
                            <button onClick={() => setYearRange(r => ({ ...r, to: Math.max(r.from, r.to - 1) }))} style={{ width: isMobile ? '20px' : '24px', height: isMobile ? '14px' : '16px', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#38bdf8', color: 'white', border: 'none', borderRadius: '4px', cursor: 'pointer', fontSize: isMobile ? '10px' : '12px', padding: 0 }}>â–¼</button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  {/* Grafik Kelahiran & Kematian dan Migrasi dipindahkan ke sini dari overview */}
                  <div style={{ display: 'flex', flexDirection: isMobile ? 'column' : 'row', gap: isMobile ? '24px' : '32px', marginBottom: '40px', width: '100%' }}>
                    {/* Grafik Kelahiran & Kematian */}
                    <div 
                      className="scroll-reveal-left delay-600 hover-lift"
                      style={{ 
                        flex: 1, 
                        background: 'white', 
                        borderRadius: isMobile ? 0 : '16px', 
                        padding: '32px', 
                        boxShadow: '0 8px 24px rgba(59,130,246,0.10)', 
                        border: '1.5px solid #e5e7eb',
                        transition: 'all 0.3s ease',
                        minHeight: isMobile ? '450px' : '480px'
                      }}>
                      <h4 style={{ fontSize: '20px', fontWeight: '700', color: '#2563eb', marginBottom: '18px', textAlign: 'center' }}>Grafik Kelahiran & Kematian per Tahun (Dinas Pendidikan Kota Palembang)</h4>
                      <div style={{ width: '100%', height: '400px', position: 'relative', display: 'block' }}>
                        <ResponsiveContainer width="100%" height={400}>
                        <RechartsLineChart
                          data={(function getKelahiranKematianData() {
                            if (typeof window === 'undefined') return [];
                            let kelahiranArr = [...kelahiranDataFromDB];
                            let kematianArr = [...kematianDataFromDB];
                            if (kelahiranArr.length === 0 || kematianArr.length === 0) return [];
                            // Filter by kecamatan jika dipilih
                            const kecamatan = selectedDistrictPopulasi;
                            if (kecamatan && kecamatan && kecamatan !== '' && kecamatan !== 'Semua Kecamatan') {
                              kelahiranArr = kelahiranArr.filter((item: any) => item.kecamatan === kecamatan);
                              kematianArr = kematianArr.filter((item: any) => item.kecamatan === kecamatan);
                            }
                            // Ambil semua tahun unik dari data yang sudah difilter kecamatan
                            const tahunSet = new Set<number>();
                            kelahiranArr.forEach((item: any) => Object.keys(item.dataByYear || {}).forEach((y: string) => tahunSet.add(parseInt(y))));
                            kematianArr.forEach((item: any) => Object.keys(item.dataByYear || {}).forEach((y: string) => tahunSet.add(parseInt(y))));
                            // Filter tahun sesuai rentang yearRange
                            const tahunArr = Array.from(tahunSet).filter((t: unknown) => typeof t === 'number' && t >= yearRange.from && t <= yearRange.to).sort((a: unknown, b: unknown) => (a as number) - (b as number));
                            // Gabungkan data kelahiran & kematian per tahun
                            return (tahunArr as number[]).map((tahun: number) => {
                              let totalKelahiran = 0, totalKematian = 0;
                              kelahiranArr.forEach((item: any) => { totalKelahiran += item.dataByYear?.[tahun]?.kelahiran ?? 0; });
                              kematianArr.forEach((item: any) => { totalKematian += item.dataByYear?.[tahun]?.kematian ?? 0; });
                              return { year: tahun, Kelahiran: totalKelahiran, Kematian: totalKematian };
                            });
                          })()}
                          margin={{ top: 20, right: 40, left: 0, bottom: 20 }}
                        >
                          <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                          <XAxis dataKey="year" stroke="#6b7280" fontSize={16} />
                          <YAxis stroke="#6b7280" />
                          <Tooltip formatter={(v, n) => (v ?? 0).toLocaleString('id-ID')} contentStyle={{ backgroundColor: 'white', border: '1.5px solid #e5e7eb', borderRadius: '12px' }} />
                          <Legend />
                          <RechartsLine type="monotone" dataKey="Kelahiran" stroke="#34d399" strokeWidth={3} dot={{ fill: '#34d399', r: 5 }} name="Kelahiran" />
                          <RechartsLine type="monotone" dataKey="Kematian" stroke="#93c5fd" strokeWidth={3} dot={{ fill: '#93c5fd', r: 5 }} name="Kematian" />
                        </RechartsLineChart>
                        </ResponsiveContainer>
                      </div>
                    </div>
                    {/* Grafik Migrasi */}
                    <div 
                      className="scroll-reveal-right delay-700 hover-lift"
                      style={{ 
                        flex: 1, 
                        background: 'white', 
                        borderRadius: isMobile ? 0 : '16px', 
                        padding: '32px', 
                        boxShadow: '0 8px 24px rgba(59,130,246,0.10)', 
                        border: '1.5px solid #e5e7eb',
                        transition: 'all 0.3s ease',
                        minHeight: isMobile ? '450px' : '480px'
                      }}>
                      <h4 style={{ fontSize: '20px', fontWeight: '700', color: '#a78bfa', marginBottom: '18px', textAlign: 'center' }}>Grafik Migrasi Masuk & Keluar per Tahun (Dinas Pendidikan Kota Palembang)</h4>
                      <div style={{ width: '100%', height: '400px', position: 'relative', display: 'block' }}>
                        <ResponsiveContainer width="100%" height={400}>
                        <BarChart
                          data={(function getMigrasiData() {
                            if (typeof window === 'undefined') return [];
                            let migrasiArr = [...migrasiDataFromDB];
                            if (migrasiArr.length === 0) return [];
                            // Filter by kecamatan jika dipilih
                            const kecamatan = selectedDistrictPopulasi;
                            if (kecamatan && kecamatan && kecamatan !== '' && kecamatan !== 'Semua Kecamatan') {
                              migrasiArr = migrasiArr.filter((item: any) => item.kecamatan === kecamatan);
                            }
                            // Ambil semua tahun unik dari data yang sudah difilter kecamatan
                            const tahunSet = new Set<number>();
                            migrasiArr.forEach((item: any) => Object.keys(item.dataByYear || {}).forEach((y: string) => tahunSet.add(parseInt(y))));
                            // Filter tahun sesuai rentang yearRange
                            const tahunArr = Array.from(tahunSet).filter((t: unknown) => typeof t === 'number' && t >= yearRange.from && t <= yearRange.to).sort((a: unknown, b: unknown) => (a as number) - (b as number));
                            // Gabungkan data migrasi masuk & keluar per tahun
                            const data = (tahunArr as number[]).map((tahun: number) => {
                              let totalMasuk = 0, totalKeluar = 0;
                              migrasiArr.forEach((item: any) => {
                                totalMasuk += item.dataByYear?.[tahun]?.masuk ?? 0;
                                totalKeluar += item.dataByYear?.[tahun]?.keluar ?? 0;
                              });
                              return { year: tahun, Masuk: totalMasuk, Keluar: totalKeluar };
                            });
                            // Reverse agar tahun 2021 di bawah, 2023 di atas
                            return data.reverse();
                          })()}
                          layout="vertical"
                          margin={{ top: 20, right: 40, left: 0, bottom: 20 }}
                        >
                          <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                          <XAxis type="number" stroke="#6b7280" fontSize={16} />
                          <YAxis dataKey="year" type="category" stroke="#6b7280" fontSize={16} width={80} />
                          <Tooltip formatter={(v, n) => (v ?? 0).toLocaleString('id-ID')} contentStyle={{ backgroundColor: 'white', border: '1.5px solid #e5e7eb', borderRadius: '12px' }} />
                          <Legend
                            verticalAlign="bottom"
                            align="center"
                            iconType="rect"
                            content={({ payload }) => (
                              <div style={{ display: 'flex', justifyContent: 'center', gap: 24, marginTop: 16 }}>
                                <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                                  <span style={{ display: 'inline-block', width: 18, height: 12, background: '#22c55e', borderRadius: 3 }}></span>
                                  <span style={{ color: '#22c55e', fontWeight: 600, fontSize: 15 }}>Masuk</span>
                                </div>
                                <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                                  <span style={{ display: 'inline-block', width: 18, height: 12, background: '#1e3a8a', borderRadius: 3 }}></span>
                                  <span style={{ color: '#1e3a8a', fontWeight: 600, fontSize: 15 }}>Keluar</span>
                                </div>
                              </div>
                            )}
                          />
                          <Bar dataKey="Keluar" fill="#1e3a8a" name="Keluar" barSize={18} />
                          <Bar dataKey="Masuk" fill="#22c55e" name="Masuk" barSize={18} />
                        </BarChart>
                        </ResponsiveContainer>
                      </div>
                    </div>
                  </div>
                  {/* Pie charts for kepadatan dan persentase penduduk restored below. */}
                  <div style={{ 
                    display: 'flex', 
                    flexDirection: isMobile ? 'column' : 'row',
                    gap: '32px', 
                    marginTop: '32px', 
                    width: '100%' 
                  }}>
                    <div style={{ flex: 1 }}>
                      {/* Toggle buttons for PieKepadatanPenduduk */}
                      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', gap: isMobile ? '6px' : '12px', marginBottom: '16px', flexWrap: 'wrap' }}>
                        <button 
                          onClick={() => setPieKepadatanMode('kecamatan')}
                          style={{
                            padding: isMobile ? '6px 12px' : '8px 18px',
                            borderRadius: '8px',
                            border: '1.5px solid #2563eb',
                            background: pieKepadatanMode === 'kecamatan' ? '#2563eb' : 'white',
                            color: pieKepadatanMode === 'kecamatan' ? 'white' : '#2563eb',
                            fontWeight: 600,
                            fontSize: isMobile ? '12px' : '15px',
                            cursor: 'pointer',
                            transition: 'all 0.3s',
                            display: 'flex',
                            alignItems: 'center',
                            gap: isMobile ? '4px' : '8px',
                            whiteSpace: 'nowrap'
                          }}
                        >
                          {pieKepadatanMode === 'kecamatan' ? (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="white" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          ) : (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="#2563eb" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          )}
                          Per Kecamatan
                        </button>
                        {/* Dropdown tahun di tengah, hanya muncul saat mode kecamatan */}
                        {pieKepadatanMode === 'kecamatan' && (
                          <select value={kepYear} onChange={e => setKepYear(Number(e.target.value))} style={{ padding: isMobile ? '6px 12px' : '8px 16px', borderRadius: 10, border: '2px solid #2563eb', fontWeight: 600, fontSize: isMobile ? 12 : 15, background: 'white', color: '#2563eb', minWidth: isMobile ? 80 : 100, flex: isMobile ? 1 : 'none', cursor: 'pointer', boxShadow: '0 2px 4px rgba(37,99,235,0.1)', transition: 'all 0.2s' }}>
                            {kepYearOptions.map(year => (
                              <option key={year} value={year}>{year}</option>
                            ))}
                          </select>
                        )}
                        <button 
                          onClick={() => setPieKepadatanMode('tahun')}
                          style={{
                            padding: isMobile ? '6px 12px' : '8px 18px',
                            borderRadius: '8px',
                            border: '1.5px solid #2563eb',
                            background: pieKepadatanMode === 'tahun' ? '#2563eb' : 'white',
                            color: pieKepadatanMode === 'tahun' ? 'white' : '#2563eb',
                            fontWeight: 600,
                            fontSize: isMobile ? '12px' : '15px',
                            cursor: 'pointer',
                            transition: 'all 0.3s',
                            display: 'flex',
                            alignItems: 'center',
                            gap: isMobile ? '4px' : '8px',
                            whiteSpace: 'nowrap'
                          }}
                        >
                          {pieKepadatanMode === 'tahun' ? (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="white" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          ) : (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="#2563eb" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          )}
                          Per Tahun
                        </button>
                      </div>
                      <PieKepadatanPenduduk 
                        mode={pieKepadatanMode} 
                        year={kepYear} 
                        jumlahPendudukData={jumlahPendudukDataFromDB}
                        luasWilayahData={luasWilayahDataFromDB}
                      />
                    </div>
                    <div style={{ flex: 1 }}>
                      {/* Toggle buttons for PiePersentasePenduduk */}
                      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', gap: isMobile ? '6px' : '12px', marginBottom: '16px', flexWrap: 'wrap' }}>
                        <button 
                          onClick={() => setPiePersentaseMode('kecamatan')}
                          style={{
                            padding: isMobile ? '6px 12px' : '8px 18px',
                            borderRadius: '8px',
                            border: '1.5px solid #8B5CF6',
                            background: piePersentaseMode === 'kecamatan' ? '#8B5CF6' : 'white',
                            color: piePersentaseMode === 'kecamatan' ? 'white' : '#8B5CF6',
                            fontWeight: 600,
                            fontSize: isMobile ? '12px' : '15px',
                            cursor: 'pointer',
                            transition: 'all 0.3s',
                            display: 'flex',
                            alignItems: 'center',
                            gap: isMobile ? '4px' : '8px',
                            whiteSpace: 'nowrap'
                          }}
                        >
                          {piePersentaseMode === 'kecamatan' ? (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="white" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          ) : (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="#8B5CF6" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          )}
                          Per Kecamatan
                        </button>
                        {/* Dropdown tahun di tengah, hanya muncul saat mode kecamatan */}
                        {piePersentaseMode === 'kecamatan' && (
                          <select value={persYear} onChange={e => setPersYear(Number(e.target.value))} style={{ padding: isMobile ? '6px 12px' : '8px 16px', borderRadius: 10, border: '2px solid #8B5CF6', fontWeight: 600, fontSize: isMobile ? 12 : 15, background: 'white', color: '#8B5CF6', minWidth: isMobile ? 80 : 100, flex: isMobile ? 1 : 'none', cursor: 'pointer', boxShadow: '0 2px 4px rgba(139,92,246,0.1)', transition: 'all 0.2s' }}>
                            {persYearOptions.map(year => (
                              <option key={year} value={year}>{year}</option>
                            ))}
                          </select>
                        )}
                        <button 
                          onClick={() => setPiePersentaseMode('tahun')}
                          style={{
                            padding: isMobile ? '6px 12px' : '8px 18px',
                            borderRadius: '8px',
                            border: '1.5px solid #8B5CF6',
                            background: piePersentaseMode === 'tahun' ? '#8B5CF6' : 'white',
                            color: piePersentaseMode === 'tahun' ? 'white' : '#8B5CF6',
                            fontWeight: 600,
                            fontSize: isMobile ? '12px' : '15px',
                            cursor: 'pointer',
                            transition: 'all 0.3s',
                            display: 'flex',
                            alignItems: 'center',
                            gap: isMobile ? '4px' : '8px',
                            whiteSpace: 'nowrap'
                          }}
                        >
                          {piePersentaseMode === 'tahun' ? (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="white" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          ) : (
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M5 10L9 14L15 8" stroke="#8B5CF6" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
                            </svg>
                          )}
                          Per Tahun
                        </button>
                      </div>
                      <PiePersentasePenduduk 
                        mode={piePersentaseMode} 
                        year={persYear}
                        jumlahPendudukData={jumlahPendudukDataFromDB}
                      />
                    </div>
                  </div>
                </div>
              </div>
            )}
            {activeTab === 'demographics' && (
              <div style={{
                background: 'linear-gradient(90deg, rgba(37,99,235,0.18) 0%, rgba(96,165,250,0.18) 100%)',
                borderRadius: isMobile ? '16px' : '24px',
                padding: isMobile ? '12px' : '24px 32px',
                marginBottom: '0px',
                minHeight: isMobile ? 'auto' : '420px',
                width: '100%',
                overflowX: isMobile ? 'hidden' : 'visible'
              }}>
                <h3 style={{ fontSize: isMobile ? '18px' : '22px', fontWeight: '700', color: '#1f2937', marginBottom: '20px' }}>
                  Statistik Demografi Penduduk
                </h3>
                {/* Responsive Year Dropdown */}
                <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'flex-start', marginBottom: 24, gap: 12 }}>
                  <label htmlFor="demogYearSelect" style={{ fontWeight: 600, fontSize: isMobile ? 12 : 15, color: '#374151' }}>Pilih Tahun:</label>
                  <select
                    id="demogYearSelect"
                    value={demogYear}
                    onChange={e => setDemogYear(Number(e.target.value))}
                    style={{ 
                      padding: isMobile ? '6px 12px' : '8px 16px', 
                      borderRadius: 10, 
                      border: '2px solid #93c5fd', 
                      fontWeight: 600, 
                      fontSize: isMobile ? 12 : 15, 
                      background: 'white',
                      color: '#1e3a8a',
                      minWidth: isMobile ? 80 : 100,
                      cursor: 'pointer',
                      boxShadow: '0 2px 4px rgba(248,113,113,0.1)',
                      transition: 'all 0.2s'
                    }}
                  >
                    {demogAvailableYears.map(y => (
                      <option key={y} value={y}>{y}</option>
                    ))}
                  </select>
                </div>
                <div style={{ display: 'flex', flexWrap: 'wrap', gap: '32px', justifyContent: 'center', alignItems: 'stretch', marginBottom: '32px' }}>
                  {/* Grafik distribusi umur & rasio jenis kelamin */}
                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: '32px', width: '100%', justifyContent: 'center', alignItems: 'stretch' }}>
                    {/* Population Pyramid */}
                    <div 
                      className="scroll-reveal-left delay-800 hover-lift"
                      style={{ 
                        flex: '1 1 400px', 
                        minWidth: isMobile ? '280px' : '340px', 
                        maxWidth: '700px', 
                        backgroundColor: 'white', 
                        borderRadius: '16px', 
                        padding: isMobile ? '16px' : '32px', 
                        boxShadow: '0 8px 24px rgba(37,99,235,0.10)', 
                        border: '1.5px solid #e5e7eb', 
                        display: 'flex', 
                        flexDirection: 'column', 
                        alignItems: 'center',
                        transition: 'all 0.3s ease',
                        minHeight: isMobile ? '650px' : '700px',
                        position: 'relative'
                      }}>
                      <h4 style={{ fontSize: '20px', fontWeight: '700', color: '#93c5fd', marginBottom: '24px', textAlign: 'center' }}>Jumlah Penduduk Menurut Kelompok Umur dan Jenis Kelamin (BPS)</h4>
                      <div style={{ width: '100%', height: '600px', position: 'relative', display: 'block' }}>
                        <ResponsiveContainer width="100%" height={600}>
                        <BarChart data={getPyramidData()} layout="vertical" margin={{ top: 10, right: 40, left: 20, bottom: 30 }}>
                          <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                          <XAxis 
                            type="number" 
                            tickFormatter={v => Math.abs(v).toLocaleString('id-ID')} 
                            stroke="#6b7280" 
                            label={{
                              value: 'Jumlah Penduduk',
                              position: 'insideBottom',
                              offset: -10,
                              style: { textAnchor: 'middle', fontWeight: 600, fontSize: 14, fill: '#374151' }
                            }}
                          />
                          <YAxis 
                            dataKey="kelompokUmur" 
                            type="category" 
                            stroke="#6b7280" 
                            width={90}
                            label={{
                              value: 'Kelompok Umur',
                              angle: -90,
                              position: 'insideLeft',
                              offset: 0,
                              style: { textAnchor: 'middle', fontWeight: 600, fontSize: 14, fill: '#374151' }
                            }}
                          />
                          <Tooltip formatter={(v, n) => [Math.abs(Number(v) || 0).toLocaleString('id-ID'), n]} labelFormatter={l => `Kelompok Umur: ${l}`} />
                          <Legend wrapperStyle={{ paddingTop: '20px' }} />
                          <Bar dataKey="Perempuan" fill="#ec4899" name="Perempuan" />
                          <Bar dataKey="Laki-laki" fill="#3b82f6" name="Laki-laki" />
                        </BarChart>
                        </ResponsiveContainer>
                      </div>
                    </div>
                    {/* Gender Ratio by Age Group */}
                    <div 
                      className="scroll-reveal-right delay-900 hover-lift"
                      style={{ 
                        flex: '1 1 400px', 
                        minWidth: isMobile ? '280px' : '340px', 
                        maxWidth: '700px', 
                        backgroundColor: 'white', 
                        borderRadius: '16px', 
                        padding: isMobile ? '16px' : '32px', 
                        boxShadow: '0 8px 24px rgba(220,38,38,0.10)', 
                        border: '1.5px solid #e5e7eb', 
                        display: 'flex', 
                        flexDirection: 'column', 
                        alignItems: 'center',
                        transition: 'all 0.3s ease',
                        minHeight: isMobile ? '650px' : '700px'
                      }}>
                      <h4 style={{ fontSize: '20px', fontWeight: '700', color: '#1e3a8a', marginBottom: '24px', textAlign: 'center' }}>Rasio Jenis Kelamin per Kelompok Umur (BPS)</h4>
                      <div style={{ width: '100%', height: '600px', position: 'relative', display: 'block' }}>
                        <ResponsiveContainer width="100%" height={600}>
                        <BarChart data={(function getGenderRatioByAgeData() {
                          // Use kelompokUmurDataFromDB state instead of localStorage
                          const arr = kelompokUmurDataFromDB;
                          if (!Array.isArray(arr) || arr.length === 0) return [];
                          
                          // Use selected year from dropdown
                          const selectedYear = demogYear;
                          
                          // Convert to format similar to laporanKelompokUmurData
                          // kelompokUmurDataFromDB format: [{kecamatan, kelompokUmur, dataByYear: {2024: {laki_laki, perempuan}}}]
                          const flatData: any[] = [];
                          arr.forEach((item: any) => {
                            const yearData = item.dataByYear?.[selectedYear];
                            if (yearData && item.kelompokUmur) {
                              flatData.push({
                                tahun: selectedYear,
                                kelompokUmur: item.kelompokUmur,
                                lakiLaki: yearData.laki_laki || 0,
                                perempuan: yearData.perempuan || 0
                              });
                            }
                          });
                          
                          // Filter skip '101'/'100' and empty
                          const filtered = flatData.filter((d: any) => d.kelompokUmur && d.kelompokUmur !== '101' && d.kelompokUmur !== '100');
                          
                          // Sort by kelompokUmur descending (so 0-4 at bottom)
                          filtered.sort((a: any, b: any) => {
                            const getStart = (s: string) => parseInt((s || '').split('-')[0]) || 0;
                            return getStart(b.kelompokUmur) - getStart(a.kelompokUmur);
                          });
                          
                          // Group by kelompokUmur
                          const grouped: { [kelompokUmur: string]: { lakiLaki: number; perempuan: number } } = {};
                          filtered.forEach((d: any) => {
                            if (!grouped[d.kelompokUmur]) grouped[d.kelompokUmur] = { lakiLaki: 0, perempuan: 0 };
                            grouped[d.kelompokUmur].lakiLaki += d.lakiLaki || 0;
                            grouped[d.kelompokUmur].perempuan += d.perempuan || 0;
                          });
                          
                          // Build chart data: Rasio = (laki-laki / perempuan) * 100
                          return Object.entries(grouped).map(([kelompokUmur, { lakiLaki, perempuan }]) => ({
                            kelompokUmur,
                            Rasio: perempuan > 0 ? Number(((lakiLaki / perempuan) * 100).toFixed(2)) : 0
                          }));
                        })()} layout="vertical" margin={{ top: 10, right: 40, left: 20, bottom: 30 }}>
                          <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                          <XAxis 
                            type="number" 
                            domain={[0, 'dataMax + 10']}
                            tickFormatter={v => (v ?? 0).toLocaleString('id-ID')}
                            stroke="#6b7280" 
                            label={{
                              value: 'Rasio (Laki-laki per 100 Perempuan)',
                              position: 'insideBottom',
                              offset: -10,
                              style: { textAnchor: 'middle', fontWeight: 600, fontSize: 14, fill: '#374151' }
                            }}
                          />
                          <YAxis 
                            dataKey="kelompokUmur" 
                            type="category" 
                            stroke="#6b7280" 
                            width={90}
                            label={{
                              value: 'Kelompok Umur',
                              angle: -90,
                              position: 'insideLeft',
                              offset: 0,
                              style: { textAnchor: 'middle', fontWeight: 600, fontSize: 14, fill: '#374151' }
                            }}
                          />
                          <Tooltip formatter={(v, n) => [Number(v).toLocaleString('id-ID'), n]} labelFormatter={l => `Kelompok Umur: ${l}`} />
                          <Legend wrapperStyle={{ paddingTop: '20px' }} />
                          <Bar dataKey="Rasio" fill="#1e3a8a" name="Rasio JK" />
                        </BarChart>
                        </ResponsiveContainer>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            )}
            {activeTab === 'growth' && (
              <div style={{ 
                maxWidth: isMobile ? '100%' : '1400px', 
                margin: '0 auto', 
                paddingLeft: isMobile ? '0' : '16px',
                paddingRight: isMobile ? '0' : '16px'
              }}>
                <div style={{
                  background: 'linear-gradient(90deg, rgba(37,99,235,0.18) 0%, rgba(96,165,250,0.18) 100%)',
                  borderRadius: isMobile ? '0' : '24px',
                  padding: isMobile ? '16px 12px' : '24px 32px',
                  marginBottom: '0px',
                  minHeight: isMobile ? 'auto' : '420px',
                  width: '100%'
                }}>
                  {/* PIE LUAS WILAYAH PER KECAMATAN */}
                  {/* Controls (title, toggle buttons, year dropdown) outside the white card, grouped above */}
                  <div style={{ marginBottom: '16px' }}>
                    <h4 style={{ fontSize: isMobile ? '16px' : '22px', fontWeight: '700', color: '#1f2937', marginBottom: '16px' }}>Distribusi Luas Wilayah per Kecamatan (BPS)</h4>
                    <div style={{ display: 'flex', flexDirection: isMobile ? 'column' : 'row', alignItems: isMobile ? 'stretch' : 'center', gap: isMobile ? '12px' : '16px', flexWrap: 'wrap' }}>
                      {/* Toggle Buttons */}
                      <div style={{ display: 'flex', gap: isMobile ? '8px' : '12px', alignItems: 'center', width: isMobile ? '100%' : 'auto' }}>
                        <button
                          onClick={() => setPieLuasMode('kecamatan')}
                          style={{
                            padding: isMobile ? '8px 16px' : '10px 20px',
                            borderRadius: 10,
                            border: '2px solid #3b82f6',
                            background: pieLuasMode === 'kecamatan' ? '#3b82f6' : 'white',
                            color: pieLuasMode === 'kecamatan' ? 'white' : '#3b82f6',
                            fontWeight: 600,
                            fontSize: isMobile ? '12px' : '15px',
                            cursor: 'pointer',
                            transition: 'all 0.2s',
                            boxShadow: pieLuasMode === 'kecamatan' ? '0 4px 8px rgba(59,130,246,0.2)' : '0 2px 4px rgba(59,130,246,0.1)',
                            flex: isMobile ? 1 : 'none'
                          }}
                        >
                          Semua Kecamatan
                        </button>
                        <button
                          onClick={() => setPieLuasMode('tahun')}
                          style={{
                            padding: isMobile ? '8px 16px' : '10px 20px',
                            borderRadius: 10,
                            border: '2px solid #64748b',
                            background: pieLuasMode === 'tahun' ? '#64748b' : 'white',
                            color: pieLuasMode === 'tahun' ? 'white' : '#64748b',
                            fontWeight: 600,
                            fontSize: isMobile ? '12px' : '15px',
                            cursor: 'pointer',
                            transition: 'all 0.2s',
                            boxShadow: pieLuasMode === 'tahun' ? '0 4px 8px rgba(100,116,139,0.2)' : '0 2px 4px rgba(100,116,139,0.1)',
                            flex: isMobile ? 1 : 'none'
                          }}
                        >
                          Total per Tahun
                        </button>
                      </div>
                      {/* Year Dropdown */}
                      {pieLuasMode === 'kecamatan' && (
                        <div style={{ display: 'flex', alignItems: 'center', gap: isMobile ? 8 : 12, width: isMobile ? '100%' : 'auto' }}>
                          <label htmlFor="pieLuasYearSelect" style={{ fontWeight: 600, fontSize: isMobile ? 12 : 15, color: '#374151' }}>Pilih Tahun:</label>
                          <select
                            id="pieLuasYearSelect"
                            value={pieLuasYear ?? pieLuasAvailableYears[pieLuasAvailableYears.length-1]}
                            onChange={e => setPieLuasYear(Number(e.target.value))}
                            style={{ 
                              padding: isMobile ? '6px 12px' : '8px 16px', 
                              borderRadius: 10, 
                              border: '2px solid #10b981', 
                              fontWeight: 600, 
                              fontSize: isMobile ? 12 : 15, 
                              background: 'white',
                              color: '#059669',
                              minWidth: isMobile ? 80 : 100,
                              flex: isMobile ? 1 : 'none',
                              cursor: 'pointer',
                              boxShadow: '0 2px 4px rgba(16,185,129,0.1)',
                              transition: 'all 0.2s'
                            }}
                          >
                            {pieLuasAvailableYears.map(y => (
                              <option key={y} value={y}>{y}</option>
                            ))}
                          </select>
                        </div>
                      )}
                    </div>
                  </div>
                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: isMobile ? '16px' : '32px', justifyContent: 'center', alignItems: 'stretch', marginBottom: isMobile ? '16px' : '32px' }}>
                    <div style={{
                      flex: '1 1 400px',
                      minWidth: '0',
                      maxWidth: '100%',
                      backgroundColor: 'white',
                      borderRadius: isMobile ? 0 : '16px',
                      padding: isMobile ? '16px 8px' : '32px',
                      boxShadow: '0 8px 24px rgba(16,185,129,0.10)',
                      border: '1.5px solid #e5e7eb',
                      display: 'flex',
                      flexDirection: isMobile ? 'column' : 'row',
                      alignItems: 'center',
                      minHeight: isMobile ? 'auto' : '520px',
                      height: 'auto',
                      justifyContent: 'center',
                      gap: isMobile ? '16px' : '32px',
                      width: '100%',
                      boxSizing: 'border-box',
                      overflow: isMobile ? 'visible' : 'hidden'
                    }}>
                      <div style={{ display: 'flex', flexDirection: isMobile ? 'column' : 'row', alignItems: 'stretch', width: '100%', gap: isMobile ? '16px' : '32px' }}>
                        <div style={{ flex: '1 1 0', minWidth: 0 }}>
                          {/* Total value outside PieChart removed as requested */}
                          <div style={{ width: '100%', height: isMobile ? '400px' : '600px', position: 'relative', display: 'block' }}>
                            <ResponsiveContainer width="100%" height={isMobile ? 400 : 600}>
                            <PieChart>
                              <Pie
                                data={pieLuasMode === 'kecamatan' ? pieLuasDataKecamatan : pieLuasDataTahun}
                                dataKey="value"
                                nameKey="name"
                                cx="50%"
                                cy="50%"
                                outerRadius={isMobile ? 120 : 220}
                                label={(props: any) => {
                                  const { value } = props;
                                  return isMobile ? `${parseFloat(value).toFixed(1)}` : `${value.toLocaleString('id-ID')} kmÂ²`;
                                }}
                                onClick={(data: any) => {
                                  if (data && data.name) {
                                    setSelectedPieLuasItem(data.name);
                                  }
                                }}
                              >
                                {(pieLuasMode === 'kecamatan' ? pieLuasDataKecamatan : pieLuasDataTahun).map((entry, idx) => (
                                  <Cell 
