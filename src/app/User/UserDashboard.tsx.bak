                                  {Number(row.value).toLocaleString('id-ID')}
                                </td>
                              </tr>
                            );
                          })}
                        </tbody>
                        <tfoot>
                          <tr style={{ 
                            background: 'linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%)',
