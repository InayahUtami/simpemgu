// Grafik LPLKM per kecamatan (AreaChart, dropdown kecamatan, gradiasi warna)
const GrafikLPLKMPerKecamatan = React.memo(function GrafikLPLKMPerKecamatan({ 
  selectedDistrict, 
  yearRange,
  kelahiranData,
  kematianData,
  migrasiData,
  pendudukData
}: { 
  selectedDistrict: string; 
  yearRange: { from: number; to: number };
  kelahiranData: any[];
  kematianData: any[];
  migrasiData: any[];
  pendudukData: any[];
}) {
  const [data, setData] = React.useState<{ year: number; lplkm: number }[]>([]);
  
  React.useEffect(() => {
    if (!kelahiranData.length || !kematianData.length || !migrasiData.length || !pendudukData.length) {
      setData([]);
      return;
    }
    
    try {
      // Determine year range to compute (ensure requested range respected)
      const fromY = yearRange?.from ?? 2018;
      const toY = yearRange?.to ?? 2024;

      // Helper to compute laju for a single kecamatan and year
      const computeLajuFor = (kecamatanName: string, tahun: number) => {
        const kelItem = kelahiranData.find((i: any) => i.kecamatan === kecamatanName);
        const kemItem = kematianData.find((i: any) => i.kecamatan === kecamatanName);
        const migItem = migrasiData.find((i: any) => i.kecamatan === kecamatanName);
        const pendItem = pendudukData.find((i: any) => i.kecamatan === kecamatanName);
        const kelahiran = kelItem?.dataByYear?.[tahun]?.kelahiran ?? 0;
        const kematian = kemItem?.dataByYear?.[tahun]?.kematian ?? 0;
        const masuk = migItem?.dataByYear?.[tahun]?.masuk ?? 0;
        const keluar = migItem?.dataByYear?.[tahun]?.keluar ?? 0;
        const penduduk = pendItem?.dataByYear?.[tahun]?.jumlahPendudukDisdukcapil ?? 0;
        if (penduduk > 0) {
          const laju = ((kelahiran - kematian + (masuk - keluar)) / penduduk) * 100;
          return Math.round(laju * 100) / 100;
        }
        return 0;
      };

      // If a district is selected, compute series for that district across the requested years
      if (selectedDistrict) {
        const series: { year: number; lplkm: number }[] = [];
        for (let y = fromY; y <= toY; y++) {
          series.push({ year: y, lplkm: computeLajuFor(selectedDistrict, y) });
        }
        setData(series);
        return;
      }

      // No district selected: compute TOTAL LPLKM (JUMLAH) across all districts per year
      // Formula: ((Total Kelahiran - Total Kematian + (Total Masuk - Total Keluar)) / Total Penduduk) * 100
      const result: { year: number; lplkm: number }[] = [];
      for (let tahun = fromY; tahun <= toY; tahun++) {
        let totalKelahiran = 0;
        let totalKematian = 0;
        let totalMigrasiMasuk = 0;
        let totalMigrasiKeluar = 0;
        let totalPenduduk = 0;

        // Sum across all kecamatan for this year
        kelahiranData.forEach((i: any) => { totalKelahiran += i.dataByYear?.[tahun]?.kelahiran ?? 0; });
        kematianData.forEach((i: any) => { totalKematian += i.dataByYear?.[tahun]?.kematian ?? 0; });
        migrasiData.forEach((i: any) => {
          totalMigrasiMasuk += i.dataByYear?.[tahun]?.masuk ?? 0;
          totalMigrasiKeluar += i.dataByYear?.[tahun]?.keluar ?? 0;
        });
        pendudukData.forEach((i: any) => { totalPenduduk += i.dataByYear?.[tahun]?.jumlahPendudukDisdukcapil ?? 0; });

        let lplkm = 0;
        if (totalPenduduk > 0) {
          lplkm = ((totalKelahiran - totalKematian + (totalMigrasiMasuk - totalMigrasiKeluar)) / totalPenduduk) * 100;
        }
        result.push({ year: tahun, lplkm: Math.round(lplkm * 100) / 100 });
      }
      setData(result);
    } catch (err) {
      setData([]);
    }
  }, [selectedDistrict, yearRange, kelahiranData, kematianData, migrasiData, pendudukData]);
  return (
    <div style={{ background: 'white', borderRadius: '12px', padding: '18px', boxShadow: '0 4px 6px rgba(0,0,0,0.06)', border: '1px solid #e5e7eb', minWidth: 0, flex: 1 }}>
      <div style={{ width: '100%', height: '300px', position: 'relative', display: 'block' }}>
        <ResponsiveContainer width="100%" height={300}>
          <AreaChart data={data} style={{ fontWeight: 700 }}>
          <defs>
            <linearGradient id="colorLajuPerKec" x1="0" y1="0" x2="0" y2="1">
              <stop offset="5%" stopColor="#2563eb" stopOpacity={0.6}/>
              <stop offset="95%" stopColor="#2563eb" stopOpacity={0.05}/>
            </linearGradient>
          </defs>
          <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
          <XAxis dataKey="year" stroke="#6b7280" style={{ fontSize: '12px', fontWeight: 400 }} />
          <YAxis stroke="#6b7280" tickFormatter={tick => `${Number(tick).toFixed(2)}%`} style={{ fontSize: '12px', fontWeight: 400 }} />
          <Tooltip formatter={(value) => `${Number(value).toFixed(2)}%`} contentStyle={{ backgroundColor: 'white', border: '1px solid #e5e7eb', borderRadius: '8px', fontWeight: 400 }} />
          <Area type="monotone" dataKey="lplkm" stroke="#2563eb" strokeWidth={4} fill="url(#colorLajuPerKec)" fillOpacity={0.6} dot={{ r: 3, stroke: '#2563eb', strokeWidth: 2, style: { fontWeight: 400 } }} name="LPLKM (Dinas Pendidikan Kota Palembang)" />
        </AreaChart>
        </ResponsiveContainer>
      </div>
      {/* Small legend for the blue chart */}
      <div style={{ marginTop: '8px', display: 'flex', justifyContent: 'center' }}>
        <div style={{ background: 'white', borderRadius: '8px', padding: '6px 10px', boxShadow: '0 2px 6px rgba(0,0,0,0.06)', border: '1px solid #e5e7eb' }}>
          <span style={{ display: 'inline-flex', alignItems: 'center', gap: '8px', fontSize: '13px', color: '#374151', fontWeight: 600 }}>
            <svg width="12" height="12" viewBox="0 0 32 32" style={{ display: 'inline-block', verticalAlign: 'middle' }} aria-hidden>
              <circle cx="16" cy="16" r="8" fill="#2563eb" />
            </svg>
            <span style={{ color: '#2563eb' }}>Laju Pertumbuhan Penduduk (Lahir,Kematian,Migrasi) - Dinas Pendidikan Kota Palembang</span>
          </span>
        </div>
      </div>
    </div>
  );
});


// Grafik JUMLAH LPLKM (total seluruh kecamatan, rumus sama dengan lplkm/page.tsx)
const GrafikJumlahLPLKM = React.memo(function GrafikJumlahLPLKM({ 
  kelahiranData, 
  kematianData, 
  migrasiData, 
  pendudukData 
}: {
  kelahiranData: any[];
  kematianData: any[];
  migrasiData: any[];
  pendudukData: any[];
}) {
  const [data, setData] = useState<{ year: number; lplkm: number }[]>([]);
  
  useEffect(() => {
    if (!kelahiranData.length || !kematianData.length || !migrasiData.length || !pendudukData.length) {
      setData([]);
      return;
    }
    
    try {
      // Ambil semua tahun unik
      const tahunSet = new Set<number>();
      kelahiranData.forEach((item: any) => Object.keys(item.dataByYear || {}).forEach((y: string) => tahunSet.add(parseInt(y))));
      kematianData.forEach((item: any) => Object.keys(item.dataByYear || {}).forEach((y: string) => tahunSet.add(parseInt(y))));
      migrasiData.forEach((item: any) => Object.keys(item.dataByYear || {}).forEach((y: string) => tahunSet.add(parseInt(y))));
      pendudukData.forEach((item: any) => Object.keys(item.dataByYear || {}).forEach((y: string) => tahunSet.add(parseInt(y))));
      const tahunArr = Array.from(tahunSet).sort((a, b) => a - b);
      
      // Hitung JUMLAH LPLKM per tahun
      const result = tahunArr.map((tahun) => {
        let totalKelahiran = 0, totalKematian = 0, totalMigrasiMasuk = 0, totalMigrasiKeluar = 0, totalPenduduk = 0;
        kelahiranData.forEach((item: any) => { totalKelahiran += item.dataByYear?.[tahun]?.kelahiran ?? 0; });
        kematianData.forEach((item: any) => { totalKematian += item.dataByYear?.[tahun]?.kematian ?? 0; });
        migrasiData.forEach((item: any) => {
          totalMigrasiMasuk += item.dataByYear?.[tahun]?.masuk ?? 0;
          totalMigrasiKeluar += item.dataByYear?.[tahun]?.keluar ?? 0;
        });
        pendudukData.forEach((item: any) => { totalPenduduk += item.dataByYear?.[tahun]?.jumlahPendudukDisdukcapil ?? 0; });
        let lplkm = 0;
        if (totalPenduduk > 0) {
          lplkm = ((totalKelahiran - totalKematian + (totalMigrasiMasuk - totalMigrasiKeluar)) / totalPenduduk) * 100;
        }
        return { year: tahun, lplkm: Math.round(lplkm * 100) / 100 };
      });
      setData(result);
    } catch {
      setData([]);
    }
  }, [kelahiranData, kematianData, migrasiData, pendudukData]);
  
  if (!data.length) return null;
  return (
    <div style={{ background: 'white', borderRadius: '16px', padding: '32px', boxShadow: '0 8px 24px rgba(59,130,246,0.10)', border: '1.5px solid #e5e7eb', marginBottom: '32px', maxWidth: '100%', width: '100%' }}>
      <h4 style={{ fontSize: '22px', fontWeight: '700', color: '#8B5CF6', marginBottom: '18px', textAlign: 'center' }}>Grafik JUMLAH LPLKM (Laju Pertumbuhan Penduduk) per Tahun</h4>
      <div style={{ width: '100%', height: '300px', position: 'relative', display: 'block' }}>
        <ResponsiveContainer width="100%" height={300}>
          <AreaChart data={data} style={{ fontWeight: 700 }}>
          <defs>
            <linearGradient id="colorLPLKM" x1="0" y1="0" x2="0" y2="1">
              <stop offset="5%" stopColor="#8B5CF6" stopOpacity={0.3}/>
              <stop offset="95%" stopColor="#8B5CF6" stopOpacity={0.05}/>
            </linearGradient>
          </defs>
          <CartesianGrid strokeDasharray="3 3" stroke="#e7eaf3" />
          <XAxis dataKey="year" stroke="#9ca3af" style={{ fontSize: '12px' }} />
          <YAxis stroke="#9ca3af" tickFormatter={tick => `${Number(tick).toFixed(2)}%`} style={{ fontSize: '12px' }} />
          <Tooltip 
            formatter={(value) => `${Number(value).toFixed(2)}%`} 
            contentStyle={{ 
              backgroundColor: 'white', 
              border: '1px solid #e5e7eb', 
              borderRadius: '8px',
              boxShadow: '0 4px 12px rgba(0,0,0,0.1)'
            }} 
          />
          <Legend 
            verticalAlign="top" 
            height={36}
            iconType="circle"
            wrapperStyle={{ fontSize: '13px', paddingBottom: '12px' }}
          />
          <Area 
            type="monotone" 
            dataKey="lplkm" 
            stroke="#8B5CF6" 
            strokeWidth={3}
            fill="url(#colorLPLKM)" 
            name="JUMLAH LPLKM (Dinas Pendidikan Kota Palembang)"
            dot={{ fill: '#8B5CF6', strokeWidth: 2, r: 4 }} 
            activeDot={{ r: 6, fill: '#8B5CF6' }}
          />
        </AreaChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
});


