                                ))}
                              </Pie>
                              <Tooltip formatter={(value: any) => `${Number(value).toLocaleString('id-ID')} kmÂ²`} />
                            </PieChart>
                            </ResponsiveContainer>
                          </div>
                        </div>
                        <div style={{ flex: '0 0 220px', minWidth: 180, marginLeft: isMobile ? 0 : '32px', marginTop: isMobile ? '24px' : 0, display: 'flex', flexDirection: 'column', alignItems: isMobile ? 'center' : 'flex-start', justifyContent: 'flex-start', height: '100%' }}>
                          {/* Custom legend manual agar selalu tampil di kanan dan responsif */}
                          <div style={{ fontSize: isMobile ? '10px' : '13px', fontWeight: 500, letterSpacing: '0.1px', width: '100%', maxHeight: isMobile ? '150px' : 'none', overflowY: isMobile ? 'auto' : 'visible', padding: isMobile ? '8px 0' : 0 }}>
                            {(pieLuasMode === 'kecamatan' ? pieLuasDataKecamatan : pieLuasDataTahun).map((entry, idx) => {
                              const isSelected = selectedPieLuasItem === entry.name;
                              return (
                                <div 
                                  key={entry.name} 
                                  onClick={() => setSelectedPieLuasItem(entry.name)}
                                  style={{ 
                                    display: 'flex', 
                                    alignItems: 'center', 
                                    marginBottom: isMobile ? 6 : 8,
                                    cursor: 'pointer',
                                    padding: isMobile ? '3px 6px' : '4px 8px',
                                    borderRadius: '6px',
                                    background: isSelected ? 'rgba(59,130,246,0.1)' : 'transparent',
                                    transition: 'all 0.2s'
                                  }}
                                >
                                  <span style={{ 
                                    display: 'inline-block', 
                                    width: isMobile ? 14 : 18, 
                                    height: isMobile ? 10 : 14, 
                                    background: pieLuasColors[idx % pieLuasColors.length], 
                                    borderRadius: 3, 
                                    marginRight: isMobile ? 6 : 8,
                                    boxShadow: isSelected ? '0 2px 8px rgba(0,0,0,0.15)' : 'none'
                                  }}></span>
                                  <span style={{ 
                                    color: isSelected ? '#1f2937' : pieLuasColors[idx % pieLuasColors.length],
                                    fontWeight: isSelected ? 700 : 500
                                  }}>{entry.name}</span>
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Tabel Luas Wilayah - Responsif dan terhubung dengan grafik pie */}
                  <div style={{ 
                    background: 'white', 
                    borderRadius: isMobile ? 0 : '16px', 
                    padding: '24px', 
                    boxShadow: '0 4px 16px rgba(0,0,0,0.08)',
                    border: '1px solid #e5e7eb',
                    marginTop: '32px'
                  }}>
                    <h4 style={{ 
                      fontSize: '18px', 
                      fontWeight: 700, 
                      color: '#1f2937', 
                      marginBottom: '16px',
                      display: 'flex',
                      alignItems: 'center',
                      gap: '8px'
                    }}>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                      </svg>
                      Detail Luas Wilayah {pieLuasMode === 'kecamatan' ? `(Tahun ${pieLuasYear ?? pieLuasAvailableYears[pieLuasAvailableYears.length-1]})` : '(Per Tahun)'}
                    </h4>
                    <div style={{ overflowX: 'auto' }}>
                      <table style={{ 
                        width: '100%', 
                        borderCollapse: 'collapse',
                        fontSize: '14px'
                      }}>
                        <thead>
                          <tr style={{ 
                            background: 'linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%)',
                            color: 'white'
                          }}>
                            <th style={{ 
                              padding: '12px 16px', 
                              textAlign: 'left', 
                              fontWeight: 700,
                              borderTopLeftRadius: '8px',
                              borderRight: '1px solid rgba(255,255,255,0.3)'
                            }}>No</th>
                            <th style={{ 
                              padding: '12px 16px', 
                              textAlign: 'left', 
                              fontWeight: 700,
                              borderRight: '1px solid rgba(255,255,255,0.3)'
                            }}>
                              {pieLuasMode === 'kecamatan' ? 'Kecamatan' : 'Tahun'}
                            </th>
                            <th style={{ 
                              padding: '12px 16px', 
                              textAlign: 'right', 
                              fontWeight: 700,
                              borderTopRightRadius: '8px'
                            }}>Luas Wilayah (kmÂ²)</th>
                          </tr>
                        </thead>
                        <tbody>
                          {(pieLuasMode === 'kecamatan' ? pieLuasDataKecamatan : pieLuasDataTahun).map((row, idx) => {
                            const isSelected = selectedPieLuasItem === row.name;
                            return (
                              <tr
                                key={`table-row-${row.name}-${idx}`}
                                onClick={() => setSelectedPieLuasItem(row.name)}
                                style={{
                                  background: isSelected 
                                    ? 'linear-gradient(90deg, rgba(59,130,246,0.15), rgba(96,165,250,0.05))' 
                                    : idx % 2 === 0 ? '#f9fafb' : 'white',
                                  cursor: 'pointer',
                                  transition: 'all 0.2s',
                                  borderBottom: '1px solid #e5e7eb'
                                }}
                                onMouseEnter={(e) => {
                                  if (!isSelected) {
                                    e.currentTarget.style.background = 'rgba(59,130,246,0.05)';
                                  }
                                }}
                                onMouseLeave={(e) => {
                                  if (!isSelected) {
                                    e.currentTarget.style.background = idx % 2 === 0 ? '#f9fafb' : 'white';
                                  }
                                }}
                              >
                                <td style={{ 
                                  padding: '12px 16px',
                                  color: isSelected ? '#2563eb' : '#6b7280',
                                  fontWeight: isSelected ? 600 : 400,
                                  borderRight: '1px solid #e5e7eb'
                                }}>{idx + 1}</td>
                                <td style={{ 
                                  padding: '12px 16px',
                                  color: isSelected ? '#2563eb' : '#1f2937',
                                  fontWeight: isSelected ? 600 : 500,
                                  display: 'flex',
                                  alignItems: 'center',
                                  gap: '8px',
                                  borderRight: '1px solid #e5e7eb'
                                }}>
                                  <span style={{ 
                                    display: 'inline-block', 
                                    width: 12, 
                                    height: 12, 
                                    background: pieLuasColors[idx % pieLuasColors.length], 
                                    borderRadius: '50%',
                                    boxShadow: isSelected ? '0 2px 6px rgba(0,0,0,0.2)' : 'none'
                                  }}></span>
                                  {row.name}
                                </td>
                                <td style={{ 
                                  padding: '12px 16px',
                                  textAlign: 'right',
