                          zIndex: 20
                        }}
                          onClick={e => {
                            e.preventDefault();
                            e.stopPropagation();
                            setDropdownOpenOverview(prev => !prev);
                            if (!dropdownOpenOverview) {
                              setSelectedDistrictOverview(''); // Reset search to show all kecamatan
                            }
                          }}
                        >
                          <svg viewBox="0 0 20 20" fill="currentColor" style={{width: 16, height: 16, opacity: 0.9, fontWeight: 'bold'}}>
                            <path fillRule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clipRule="evenodd" strokeWidth="1.5"/>
                          </svg>
