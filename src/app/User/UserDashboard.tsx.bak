// Custom Hook untuk Scroll Reveal Animation seperti website Satudata Kemendag
const useScrollReveal = (deps: any[] = []) => {
  useEffect(() => {
    if (typeof window === 'undefined') return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('reveal-visible');
          }
        });
      },
      {
        threshold: 0.05,
        rootMargin: '0px 0px -10px 0px'
      }
    );

    // Small delay to ensure DOM is ready
    const timer = setTimeout(() => {
      // Observe semua elemen dengan class scroll-reveal
      const elements = document.querySelectorAll('.scroll-reveal, .scroll-reveal-left, .scroll-reveal-right, .scroll-reveal-scale');
      elements.forEach((el) => {
        observer.observe(el);
        // Trigger immediately for elements already in viewport
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          el.classList.add('reveal-visible');
        }
      });
    }, 100);

    return () => {
      clearTimeout(timer);
      observer.disconnect();
    };
  }, deps);
};

// Global Styles untuk Scroll Reveal
if (typeof window !== 'undefined') {
  const style = document.createElement('style');
  style.textContent = `
    .scroll-reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    
    .scroll-reveal.reveal-visible {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }
    
    .scroll-reveal-left {
      opacity: 0;
      transform: translateX(-30px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    
    .scroll-reveal-left.reveal-visible {
      opacity: 1 !important;
      transform: translateX(0) !important;
    }
    
    .scroll-reveal-right {
      opacity: 0;
      transform: translateX(30px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    
    .scroll-reveal-right.reveal-visible {
      opacity: 1 !important;
      transform: translateX(0) !important;
    }
    
    .scroll-reveal-scale {
      opacity: 0;
      transform: scale(0.95);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    
    .scroll-reveal-scale.reveal-visible {
      opacity: 1 !important;
      transform: scale(1) !important;
    }
    
    /* Mobile: Disable animations to prevent shaking */
    @media (max-width: 768px) {
      .scroll-reveal,
      .scroll-reveal-left,
      .scroll-reveal-right,
      .scroll-reveal-scale {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      
      .hover-lift,
      .hover-scale {
        transition: none !important;
      }
      
      .hover-lift:hover,
      .hover-scale:hover {
        transform: none !important;
      }
    }
    
    .delay-100 { transition-delay: 0.1s; }
    .delay-200 { transition-delay: 0.2s; }
    .delay-300 { transition-delay: 0.3s; }
    .delay-400 { transition-delay: 0.4s; }
    .delay-500 { transition-delay: 0.5s; }
    .delay-600 { transition-delay: 0.6s; }
    .delay-700 { transition-delay: 0.7s; }
    .delay-800 { transition-delay: 0.8s; }
    .delay-900 { transition-delay: 0.9s; }
    .delay-1000 { transition-delay: 1s; }
    .delay-1100 { transition-delay: 1.1s; }
    .delay-1200 { transition-delay: 1.2s; }
    
    /* Hover Effects */
    .hover-lift {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .hover-lift:hover {
      transform: translateY(-8px) !important;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
    }
    
    .hover-scale {
      transition: all 0.3s ease;
    }
    
    .hover-scale:hover {
      transform: scale(1.03) !important;
    }
    
    /* Shimmer Effect */
    @keyframes shimmer {
      0% { background-position: -1000px 0; }
      100% { background-position: 1000px 0; }
    }
    
    .shimmer-effect {
      position: relative;
      overflow: hidden;
    }
    
    .shimmer-effect::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(255, 255, 255, 0.3),
        transparent
      );
      animation: shimmer 2s infinite;
    }
    
    /* Float Animation */
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    
    .float-animation {
      animation: float 3s ease-in-out infinite;
    }
    
    /* Pulse Icon Animation for FAQ */
    @keyframes pulse-icon {
      0%, 100% { 
        transform: scale(1);
        box-shadow: 0 8px 24px rgba(37,99,235,0.3);
      }
      50% { 
        transform: scale(1.05);
        box-shadow: 0 12px 32px rgba(37,99,235,0.4);
      }
    }
  `;
  document.head.appendChild(style);
}

const getYearsRange = () => {
  const currentYear = new Date().getFullYear();
  return {
    minYear: 2018,
    maxYear: currentYear + 3 // Allow projection up to 3 years into the future
  };
};

export default function AdminDashboard() {
  // Responsive state for FAQ section
  const [isMobile, setIsMobile] = React.useState(false);
  React.useEffect(() => {
    if (typeof window !== 'undefined') {
      setIsMobile(window.innerWidth <= 768);
      const handleResize = () => setIsMobile(window.innerWidth <= 768);
      window.addEventListener('resize', handleResize);
      return () => window.removeEventListener('resize', handleResize);
    }
  }, []);
  const router = useRouter();
  
  // Global data state from database
  const [dashboardData, setDashboardData] = useState<any>(null);
  const [dashboardStats, setDashboardStats] = useState<any>(null);
  const [isLoadingData, setIsLoadingData] = useState(true);
  const [kelompokUmurDataFromDB, setKelompokUmurDataFromDB] = useState<any[]>([]);
  const [mountKey, setMountKey] = useState(0);

  // Error state for fetch
  const [fetchError, setFetchError] = useState<string | null>(null);

  // Force clean state on mount to prevent stale content
  useEffect(() => {
    // Reset all data states
    setDashboardData(null);
    setDashboardStats(null);
    setKelompokUmurDataFromDB([]);
    setIsLoadingData(true);
    setFetchError(null);
    
    // Increment mount key to force re-render
    setMountKey(prev => prev + 1);
  }, []);

  // Fetch all dashboard data from API on mount
  useEffect(() => {
    // Skip fetch on first render (before state clean)
    if (mountKey === 0) return;
    
    const controller = new AbortController();
    const signal = controller.signal;
    
    const fetchDashboardData = async () => {
      try {
        setIsLoadingData(true);
        setFetchError(null);

        // Add timestamp to prevent caching (especially on mobile)
        const timestamp = new Date().getTime();
        
        // Fetch all data in parallel with abort signal and cache-busting
        const [dataResponse, statsResponse] = await Promise.all([
          fetch(`/api/dashboard/data?t=${timestamp}`, { 
            cache: 'no-store', 
            signal,
            headers: {
              'Cache-Control': 'no-cache, no-store, must-revalidate',
              'Pragma': 'no-cache',
              'Expires': '0'
            }
          }),
          fetch(`/api/dashboard/stats?t=${timestamp}`, { 
            cache: 'no-store', 
            signal,
            headers: {
              'Cache-Control': 'no-cache, no-store, must-revalidate',
              'Pragma': 'no-cache',
              'Expires': '0'
            }
          })
        ]);


        // Check for valid JSON responses
        if (!dataResponse.ok || !statsResponse.ok) {
          setFetchError('API error: One or more endpoints returned an error');
          return;
        }

        let dataResult, statsResult;
        try {
          if (dataResponse.headers.get('content-type')?.includes('application/json')) {
            dataResult = await dataResponse.json();
          } else {
            setFetchError('API /api/dashboard/data did not return JSON');
            return;
          }
        } catch (err) {
          setFetchError('API /api/dashboard/data did not return valid JSON');
          return;
        }
        try {
          if (statsResponse.headers.get('content-type')?.includes('application/json')) {
            statsResult = await statsResponse.json();
          } else {
            setFetchError('API /api/dashboard/stats did not return JSON');
            return;
          }
        } catch (err) {
          setFetchError('API /api/dashboard/stats did not return valid JSON');
          return;
        }

        console.log('Dashboard Data from Database:', dataResult);
        console.log('Dashboard Stats from Database:', statsResult);

        if (dataResult.success) {
          // Cek apakah data kosong
          const d = dataResult.data;
          if (!d || !d.luasWilayah?.length || !d.jumlahPenduduk?.length || !d.kelahiran?.length || !d.kematian?.length || !d.migrasi?.length) {
            setFetchError('Data dashboard kosong atau tidak lengkap.');
            return;
          }
          setDashboardData(d);
        } else {
          setFetchError('Data dashboard tidak ditemukan atau format salah');
          return;
        }

        if (statsResult.success) {
          setDashboardStats(statsResult.data);
        } else {
          setFetchError('Statistik dashboard tidak ditemukan atau format salah');
          return;
        }
      } catch (error: any) {
        // Ignore AbortError when component unmounts
        if (error.name === 'AbortError') {
          console.log('Fetch aborted - navigating away from dashboard');
          return;
        }
        setFetchError(error?.message || 'Gagal fetch data dashboard');
        console.error('Error fetching dashboard data:', error);
      } finally {
        if (!signal.aborted) {
          setIsLoadingData(false);
        }
      }
    };

    fetchDashboardData();
    
    // Cleanup: abort fetch when navigating away
    return () => {
      controller.abort();
    };
  }, [mountKey]);


  // Show error in UI if fetchError is set
  if (fetchError) {
    return (
      <div style={{ color: '#1e3a8a', background: '#fff', borderRadius: 12, padding: 24, margin: 32, fontWeight: 600, fontSize: 18 }}>
        Error: {fetchError}
      </div>
    );
  }

  // Extract data from dashboardData with fallback to empty arrays
  const luasWilayahDataFromDB = dashboardData?.luasWilayah || [];
  const jumlahPendudukDataFromDB = dashboardData?.jumlahPenduduk || [];
  const kelahiranDataFromDB = dashboardData?.kelahiran || [];
  const kematianDataFromDB = dashboardData?.kematian || [];
  const migrasiDataFromDB = dashboardData?.migrasi || [];
  const jumlahPendudukDisdukcapilDataFromDB = dashboardData?.jumlahPendudukDisdukcapil || [];
  const kecamatanListFromDB = dashboardData?.kecamatan || [];

  // Debug: Log extracted data
  useEffect(() => {
    console.log('Extracted Data from Database:', {
      luasWilayah: luasWilayahDataFromDB.length,
      jumlahPenduduk: jumlahPendudukDataFromDB.length,
      kelahiran: kelahiranDataFromDB.length,
      kematian: kematianDataFromDB.length,
      migrasi: migrasiDataFromDB.length,
      disdukcapil: jumlahPendudukDisdukcapilDataFromDB.length
    });
    
    if (jumlahPendudukDataFromDB.length > 0) {
      console.log('Sample Jumlah Penduduk Data:', jumlahPendudukDataFromDB[0]);
    }
    
    if (luasWilayahDataFromDB.length > 0) {
      console.log('Sample Luas Wilayah Data:', luasWilayahDataFromDB[0]);
    }
  }, [luasWilayahDataFromDB, jumlahPendudukDataFromDB, kelahiranDataFromDB, kematianDataFromDB, migrasiDataFromDB, jumlahPendudukDisdukcapilDataFromDB]);

  // Pie Luas Wilayah State
  const [pieLuasMode, setPieLuasMode] = useState<'kecamatan' | 'tahun'>('kecamatan');
  const [pieLuasYear, setPieLuasYear] = useState<number | null>(null);
